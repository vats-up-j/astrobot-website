---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
---

<Layout title="Features - HoroTalk | Vedic Astrology Reports on WhatsApp">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-ivory via-primary-light to-ivory py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-8">
      <p class="text-sm text-charcoal/40 mb-2">
        <a href="/" class="hover:text-maroon">Home</a> &rsaquo; <span class="i18n" data-en="Features" data-hi="&#x0938;&#x0941;&#x0935;&#x093F;&#x0927;&#x093E;&#x090F;&#x0902;">Features</span>
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-charcoal i18n" data-en="What Guruji Can Do for You" data-hi="&#x0917;&#x0941;&#x0930;&#x0941;&#x091C;&#x0940; &#x0906;&#x092A;&#x0915;&#x0947; &#x0932;&#x093F;&#x090F; &#x0915;&#x094D;&#x092F;&#x093E; &#x0915;&#x0930; &#x0938;&#x0915;&#x0924;&#x0947; &#x0939;&#x0948;&#x0902;">What Guruji Can Do for You</h1>
      <p class="mt-3 text-charcoal/55 max-w-2xl i18n" data-en="Real Vedic calculations. AI-powered interpretation. Beautiful PDF reports delivered on WhatsApp in seconds. No app to download, no sign-up forms." data-hi="&#x0935;&#x093E;&#x0938;&#x094D;&#x0924;&#x0935;&#x093F;&#x0915; &#x0935;&#x0948;&#x0926;&#x093F;&#x0915; &#x0917;&#x0923;&#x0928;&#x093E;&#x0964; AI &#x0935;&#x094D;&#x092F;&#x093E;&#x0916;&#x094D;&#x092F;&#x093E;&#x0964; &#x0938;&#x0941;&#x0902;&#x0926;&#x0930; PDF &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F; WhatsApp &#x092A;&#x0930; &#x0938;&#x0947;&#x0915;&#x0902;&#x0921;&#x094B;&#x0902; &#x092E;&#x0947;&#x0902;&#x0964; &#x0915;&#x094B;&#x0908; &#x0910;&#x092A; &#x0928;&#x0939;&#x0940;&#x0902;, &#x0915;&#x094B;&#x0908; &#x0938;&#x093E;&#x0907;&#x0928;-&#x0905;&#x092A; &#x0928;&#x0939;&#x0940;&#x0902;&#x0964;">Real Vedic calculations. AI-powered interpretation. Beautiful PDF reports delivered on WhatsApp in seconds. No app to download, no sign-up forms.</p>
    </div>
  </section>

  <!-- 5 Reports + Q&A -->
  <section class="py-10 sm:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-8">

      <h2 class="text-xl sm:text-2xl font-bold text-charcoal mb-2 i18n" data-en="Detailed PDF Reports" data-hi="&#x0935;&#x093F;&#x0938;&#x094D;&#x0924;&#x0943;&#x0924; PDF &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F;">Detailed PDF Reports</h2>
      <p class="text-sm text-charcoal/50 mb-8 i18n" data-en="Each report is 12-15 pages with Lagna and Navamsa charts, planetary positions, Dasha timeline, and personalized AI interpretation." data-hi="&#x0939;&#x0930; &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F; 12-15 &#x092A;&#x0947;&#x091C; &#x0915;&#x093E; &#x0939;&#x0948;&#x0964; &#x0932;&#x0917;&#x094D;&#x0928; &#x0914;&#x0930; &#x0928;&#x0935;&#x093E;&#x0902;&#x0936; &#x091A;&#x093E;&#x0930;&#x094D;&#x091F;, &#x0917;&#x094D;&#x0930;&#x0939; &#x0938;&#x094D;&#x0925;&#x093F;&#x0924;&#x093F;, &#x0926;&#x0936;&#x093E; &#x0938;&#x092E;&#x092F;&#x0930;&#x0947;&#x0916;&#x093E; &#x0914;&#x0930; AI &#x0935;&#x094D;&#x092F;&#x093E;&#x0916;&#x094D;&#x092F;&#x093E;&#x0964;">Each report is 12-15 pages with Lagna and Navamsa charts, planetary positions, Dasha timeline, and personalized AI interpretation.</p>

      <div class="space-y-4">
        <!-- Janam Kundli -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x2728;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Janam Kundli (Birth Chart)" data-hi="&#x091C;&#x0928;&#x094D;&#x092E; &#x0915;&#x0941;&#x0902;&#x0921;&#x0932;&#x0940;">Janam Kundli (Birth Chart)</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Your complete Vedic birth chart computed from real planetary positions at degree-level precision. Includes Lagna chart, Navamsa (D9) chart, all planet positions with degrees and retrograde status, Nakshatra details, Vimshottari Mahadasha timeline, personality analysis across multiple life areas (career, love, communication, drive), planetary aspects with orbs, and a personalized path forward." data-hi="&#x0921;&#x093F;&#x0917;&#x094D;&#x0930;&#x0940;-&#x0938;&#x094D;&#x0924;&#x0930; &#x0915;&#x0940; &#x0938;&#x091F;&#x0940;&#x0915;&#x0924;&#x093E; &#x0938;&#x0947; &#x0906;&#x092A;&#x0915;&#x0940; &#x092A;&#x0942;&#x0930;&#x094D;&#x0923; &#x0935;&#x0948;&#x0926;&#x093F;&#x0915; &#x091C;&#x0928;&#x094D;&#x092E; &#x0915;&#x0941;&#x0902;&#x0921;&#x0932;&#x0940;&#x0964; &#x0932;&#x0917;&#x094D;&#x0928; &#x091A;&#x093E;&#x0930;&#x094D;&#x091F;, &#x0928;&#x0935;&#x093E;&#x0902;&#x0936; &#x091A;&#x093E;&#x0930;&#x094D;&#x091F;, &#x0917;&#x094D;&#x0930;&#x0939; &#x0938;&#x094D;&#x0925;&#x093F;&#x0924;&#x093F;, &#x0928;&#x0915;&#x094D;&#x0937;&#x0924;&#x094D;&#x0930;, &#x092E;&#x0939;&#x093E;&#x0926;&#x0936;&#x093E; &#x0938;&#x092E;&#x092F;&#x0930;&#x0947;&#x0916;&#x093E;, &#x0935;&#x094D;&#x092F;&#x0915;&#x094D;&#x0924;&#x093F;&#x0924;&#x094D;&#x0935; &#x0935;&#x093F;&#x0936;&#x094D;&#x0932;&#x0947;&#x0937;&#x0923; &#x0914;&#x0930; &#x091C;&#x0940;&#x0935;&#x0928; &#x092E;&#x093E;&#x0930;&#x094D;&#x0917;&#x0926;&#x0930;&#x094D;&#x0936;&#x0928;&#x0964;">Your complete Vedic birth chart computed from real planetary positions at degree-level precision. Includes Lagna chart, Navamsa (D9) chart, all planet positions with degrees and retrograde status, Nakshatra details, Vimshottari Mahadasha timeline, personality analysis across multiple life areas (career, love, communication, drive), planetary aspects with orbs, and a personalized path forward.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Lagna + Navamsa Charts</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Dasha Timeline</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Personality Analysis</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Aspects + Yogas</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;99</span>
          </div>
        </div>

        <!-- Career -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x1F4BC;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Career &amp; Finance Report" data-hi="&#x0915;&#x0930;&#x093F;&#x092F;&#x0930; &#x0914;&#x0930; &#x0935;&#x093F;&#x0924;&#x094D;&#x0924; &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F;">Career &amp; Finance Report</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Deep analysis of your 10th house, Dasha-based career trajectory, professional strengths, best career fields for your chart, financial blueprint, and a 2-3 year career outlook. Ideal for job changes, business decisions, or career planning." data-hi="10&#x0935;&#x0947;&#x0902; &#x092D;&#x093E;&#x0935; &#x0915;&#x093E; &#x0917;&#x0939;&#x0928; &#x0935;&#x093F;&#x0936;&#x094D;&#x0932;&#x0947;&#x0937;&#x0923;, &#x0926;&#x0936;&#x093E;-&#x0906;&#x0927;&#x093E;&#x0930;&#x093F;&#x0924; &#x0915;&#x0930;&#x093F;&#x092F;&#x0930; &#x092A;&#x0925;, &#x092A;&#x0947;&#x0936;&#x0947;&#x0935;&#x0930; &#x0936;&#x0915;&#x094D;&#x0924;&#x093F;&#x092F;&#x093E;&#x0902;, &#x0935;&#x093F;&#x0924;&#x094D;&#x0924;&#x0940;&#x092F; &#x092F;&#x094B;&#x091C;&#x0928;&#x093E; &#x0914;&#x0930; 2-3 &#x0935;&#x0930;&#x094D;&#x0937; &#x0915;&#x093E; &#x0926;&#x0943;&#x0937;&#x094D;&#x091F;&#x093F;&#x0915;&#x094B;&#x0923;&#x0964;">Deep analysis of your 10th house, Dasha-based career trajectory, professional strengths, best career fields for your chart, financial blueprint, and a 2-3 year career outlook. Ideal for job changes, business decisions, or career planning.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">10th House Analysis</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Financial Blueprint</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">2-3 Year Outlook</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;149</span>
          </div>
        </div>

        <!-- Love -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x2764;&#xFE0F;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Love &amp; Marriage Report" data-hi="&#x092A;&#x094D;&#x0930;&#x0947;&#x092E; &#x0914;&#x0930; &#x0935;&#x093F;&#x0935;&#x093E;&#x0939; &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F;">Love &amp; Marriage Report</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Venus, Mars, and 7th house analysis revealing your love style, ideal partner profile, Manglik dosha check with remedies, marriage timing windows, and relationship challenges to watch for." data-hi="&#x0936;&#x0941;&#x0915;&#x094D;&#x0930;, &#x092E;&#x0902;&#x0917;&#x0932; &#x0914;&#x0930; 7&#x0935;&#x0947;&#x0902; &#x092D;&#x093E;&#x0935; &#x0915;&#x093E; &#x0935;&#x093F;&#x0936;&#x094D;&#x0932;&#x0947;&#x0937;&#x0923;&#x0964; &#x092A;&#x094D;&#x0930;&#x0947;&#x092E; &#x0936;&#x0948;&#x0932;&#x0940;, &#x0906;&#x0926;&#x0930;&#x094D;&#x0936; &#x0938;&#x093E;&#x0925;&#x0940;, &#x092E;&#x093E;&#x0902;&#x0917;&#x0932;&#x093F;&#x0915; &#x0926;&#x094B;&#x0937; &#x091C;&#x093E;&#x0902;&#x091A; &#x0914;&#x0930; &#x0935;&#x093F;&#x0935;&#x093E;&#x0939; &#x0915;&#x093E; &#x0938;&#x092E;&#x092F;&#x0964;">Venus, Mars, and 7th house analysis revealing your love style, ideal partner profile, Manglik dosha check with remedies, marriage timing windows, and relationship challenges to watch for.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Partner Profile</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Manglik Check</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Marriage Timing</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;149</span>
          </div>
        </div>

        <!-- Dasha -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x1F52E;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Life Phases (Dasha) Report" data-hi="&#x091C;&#x0940;&#x0935;&#x0928; &#x091A;&#x0930;&#x0923; (&#x0926;&#x0936;&#x093E;) &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F;">Life Phases (Dasha) Report</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Complete Vimshottari Dasha analysis with Mahadasha, Antardasha, and Pratyantardasha breakdowns. Covers your current planetary period, life events timeline, what the next 3 major transitions will bring, and how to prepare for each phase." data-hi="&#x092E;&#x0939;&#x093E;&#x0926;&#x0936;&#x093E;, &#x0905;&#x0902;&#x0924;&#x0930;&#x0926;&#x0936;&#x093E; &#x0914;&#x0930; &#x092A;&#x094D;&#x0930;&#x0924;&#x094D;&#x092F;&#x0902;&#x0924;&#x0930;&#x0926;&#x0936;&#x093E; &#x0915;&#x0947; &#x0938;&#x093E;&#x0925; &#x092A;&#x0942;&#x0930;&#x094D;&#x0923; &#x0935;&#x093F;&#x092E;&#x094D;&#x0936;&#x094B;&#x0924;&#x094D;&#x0924;&#x0930;&#x0940; &#x0926;&#x0936;&#x093E; &#x0935;&#x093F;&#x0936;&#x094D;&#x0932;&#x0947;&#x0937;&#x0923;&#x0964; &#x0935;&#x0930;&#x094D;&#x0924;&#x092E;&#x093E;&#x0928; &#x0917;&#x094D;&#x0930;&#x0939; &#x0915;&#x093E;&#x0932;, &#x091C;&#x0940;&#x0935;&#x0928; &#x0918;&#x091F;&#x0928;&#x093E; &#x0938;&#x092E;&#x092F;&#x0930;&#x0947;&#x0916;&#x093E; &#x0914;&#x0930; &#x0905;&#x0917;&#x0932;&#x0947; 3 &#x092A;&#x0930;&#x093F;&#x0935;&#x0930;&#x094D;&#x0924;&#x0928;&#x0964;">Complete Vimshottari Dasha analysis with Mahadasha, Antardasha, and Pratyantardasha breakdowns. Covers your current planetary period, life events timeline, what the next 3 major transitions will bring, and how to prepare for each phase.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Current Dasha</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Life Timeline</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Next 3 Transitions</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;199</span>
          </div>
        </div>

        <!-- Matching -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x1F491;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Kundli Matching Report" data-hi="&#x0915;&#x0941;&#x0902;&#x0921;&#x0932;&#x0940; &#x092E;&#x093F;&#x0932;&#x093E;&#x0928; &#x0930;&#x093F;&#x092A;&#x094B;&#x0930;&#x094D;&#x091F;">Kundli Matching Report</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Two-person compatibility analysis using the Ashtakoot Guna Milan system. Scores across all 8 categories (Varna, Vashya, Tara, Yoni, Graha Maitri, Gana, Bhakoot, Nadi), Manglik dosha cross-check, synastry analysis, and detailed relationship guidance." data-hi="&#x0905;&#x0937;&#x094D;&#x091F;&#x0915;&#x0942;&#x091F; &#x0917;&#x0941;&#x0923; &#x092E;&#x093F;&#x0932;&#x093E;&#x0928; &#x092A;&#x094D;&#x0930;&#x0923;&#x093E;&#x0932;&#x0940; &#x0938;&#x0947; &#x0926;&#x094B; &#x0935;&#x094D;&#x092F;&#x0915;&#x094D;&#x0924;&#x093F;&#x092F;&#x094B;&#x0902; &#x0915;&#x0940; &#x0905;&#x0928;&#x0941;&#x0915;&#x0942;&#x0932;&#x0924;&#x093E; &#x0935;&#x093F;&#x0936;&#x094D;&#x0932;&#x0947;&#x0937;&#x0923;&#x0964; &#x0938;&#x092D;&#x0940; 8 &#x0936;&#x094D;&#x0930;&#x0947;&#x0923;&#x093F;&#x092F;&#x094B;&#x0902; &#x092E;&#x0947;&#x0902; &#x0905;&#x0902;&#x0915;, &#x092E;&#x093E;&#x0902;&#x0917;&#x0932;&#x093F;&#x0915; &#x0926;&#x094B;&#x0937; &#x091C;&#x093E;&#x0902;&#x091A; &#x0914;&#x0930; &#x0930;&#x093F;&#x0936;&#x094D;&#x0924;&#x093E; &#x092E;&#x093E;&#x0930;&#x094D;&#x0917;&#x0926;&#x0930;&#x094D;&#x0936;&#x0928;&#x0964;">Two-person compatibility analysis using the Ashtakoot Guna Milan system. Scores across all 8 categories (Varna, Vashya, Tara, Yoni, Graha Maitri, Gana, Bhakoot, Nadi), Manglik dosha cross-check, synastry analysis, and detailed relationship guidance.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">36-Point Guna Milan</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Dosha Check</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Synastry</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;249</span>
          </div>
        </div>

        <!-- Ask Questions -->
        <div class="bg-white rounded-xl p-5 sm:p-6 shadow-sm border border-charcoal/5 hover:border-gold/20 hover:shadow-md transition-all">
          <div class="flex items-start gap-4">
            <span class="text-3xl flex-shrink-0">&#x1F4AC;</span>
            <div class="flex-1">
              <h3 class="text-base sm:text-lg font-bold text-charcoal mb-1 i18n" data-en="Ask Guruji Anything" data-hi="&#x0917;&#x0941;&#x0930;&#x0941;&#x091C;&#x0940; &#x0938;&#x0947; &#x0915;&#x0941;&#x091B; &#x092D;&#x0940; &#x092A;&#x0942;&#x091B;&#x0947;&#x0902;">Ask Guruji Anything</h3>
              <p class="text-sm text-charcoal/55 leading-relaxed i18n" data-en="Open-ended astrology questions answered based on your birth chart. Ask about career moves, relationship timing, travel decisions, health concerns, or any life question. Guruji reads your chart and gives personalized guidance rooted in Vedic principles." data-hi="&#x0906;&#x092A;&#x0915;&#x0940; &#x0915;&#x0941;&#x0902;&#x0921;&#x0932;&#x0940; &#x0915;&#x0947; &#x0906;&#x0927;&#x093E;&#x0930; &#x092A;&#x0930; &#x091C;&#x094D;&#x092F;&#x094B;&#x0924;&#x093F;&#x0937; &#x092A;&#x094D;&#x0930;&#x0936;&#x094D;&#x0928;&#x094B;&#x0902; &#x0915;&#x0947; &#x0909;&#x0924;&#x094D;&#x0924;&#x0930;&#x0964; &#x0915;&#x0930;&#x093F;&#x092F;&#x0930;, &#x0930;&#x093F;&#x0936;&#x094D;&#x0924;&#x0947;, &#x092F;&#x093E;&#x0924;&#x094D;&#x0930;&#x093E;, &#x0938;&#x094D;&#x0935;&#x093E;&#x0938;&#x094D;&#x0925;&#x094D;&#x092F; &#x092F;&#x093E; &#x0915;&#x094B;&#x0908; &#x092D;&#x0940; &#x091C;&#x0940;&#x0935;&#x0928; &#x092A;&#x094D;&#x0930;&#x0936;&#x094D;&#x0928; &#x092A;&#x0942;&#x091B;&#x0947;&#x0902;&#x0964; &#x0917;&#x0941;&#x0930;&#x0941;&#x091C;&#x0940; &#x0935;&#x0948;&#x0926;&#x093F;&#x0915; &#x0938;&#x093F;&#x0926;&#x094D;&#x0927;&#x093E;&#x0902;&#x0924;&#x094B;&#x0902; &#x092A;&#x0930; &#x0906;&#x0927;&#x093E;&#x0930;&#x093F;&#x0924; &#x092E;&#x093E;&#x0930;&#x094D;&#x0917;&#x0926;&#x0930;&#x094D;&#x0936;&#x0928; &#x0926;&#x0947;&#x0924;&#x0947; &#x0939;&#x0948;&#x0902;&#x0964;">Open-ended astrology questions answered based on your birth chart. Ask about career moves, relationship timing, travel decisions, health concerns, or any life question. Guruji reads your chart and gives personalized guidance rooted in Vedic principles.</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Any Topic</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Chart-Based Answers</span>
                <span class="text-[10px] bg-maroon/5 text-maroon px-2 py-0.5 rounded-full font-medium">Hindi &amp; English</span>
              </div>
            </div>
            <span class="text-lg font-bold text-maroon flex-shrink-0">&#8377;15<span class="text-xs font-normal text-charcoal/40">/q</span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it's built -->
  <section class="py-10 sm:py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <h2 class="text-xl sm:text-2xl font-bold text-charcoal mb-2 i18n" data-en="How Guruji Reads Your Chart" data-hi="&#x0917;&#x0941;&#x0930;&#x0941;&#x091C;&#x0940; &#x0906;&#x092A;&#x0915;&#x0940; &#x0915;&#x0941;&#x0902;&#x0921;&#x0932;&#x0940; &#x0915;&#x0948;&#x0938;&#x0947; &#x092A;&#x0922;&#x093C;&#x0924;&#x0947; &#x0939;&#x0948;&#x0902;">How Guruji Reads Your Chart</h2>
      <div class="w-10 h-0.5 bg-gold rounded-full mb-6"></div>

      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-ivory rounded-xl p-5 border border-charcoal/5">
