---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Features - AstroBot">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-primary">Home</a> &rsaquo; Features
      </p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight">Everything You Need for<br/>Astrology Readings</h1>
      <p class="mt-4 text-text-light max-w-3xl text-lg">
        AstroBot combines AI-powered astrology with traditional Vedic and Western systems. From instant birth chart generation to personalized Dasha predictions, daily Panchang timings to Kundli matching — every tool you need, right on WhatsApp.
      </p>
    </div>
  </section>

  <!-- Feature Cards -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- AI Astrology Chat -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">AI Astrology Chat</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Ask any astrology question and get instant, personalized answers. Chat with an AI Vedic astrologer that understands your birth chart.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Ask about career, relationships, health, finance, or any life question and get answers rooted in your unique planetary positions, dashas, and yogas.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Chart-Aware Answers</span>
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Hindi & English</span>
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Follow-up Context</span>
          </div>
        </div>

        <!-- Birth Chart -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Birth Chart (Kundli)</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Generate your complete Kundli with accurate planetary positions, house placements, and divisional charts instantly.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            View North Indian and South Indian chart styles, with detailed planet tables showing degrees, nakshatras, and retrograde status.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Multiple Chart Types</span>
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">North & South Indian</span>
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Precise Calculations</span>
          </div>
        </div>

        <!-- Daily Panchang -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Daily Panchang</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Know today's tithi, nakshatra, yoga, and auspicious timings instantly.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Check the daily Vedic Panchang with all five elements — Tithi, Nakshatra, Yoga, Karana, and Var. Get Choghadiya, Rahu Kaal, and auspicious muhurtas for any date and location.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Five Panchang Elements</span>
            <span class="text-xs bg-primary-light text-primary px-2.5 py-1 rounded-full">Choghadiya Timings</span>
          </div>
        </div>

        <!-- Kundli Matching -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Kundli Matching</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Check Ashtakoot compatibility for marriage and relationships.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Match two birth charts using the traditional Ashtakoot (8-point) compatibility system. Get detailed Guna scores across all 8 categories with an overall compatibility percentage.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-red-50 text-red-500 px-2.5 py-1 rounded-full">Ashtakoot Scoring</span>
            <span class="text-xs bg-red-50 text-red-500 px-2.5 py-1 rounded-full">Relationship Insights</span>
          </div>
        </div>

        <!-- Dasha Predictions -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Dasha Predictions</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Know your current planetary period and what to expect.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Get Vimshottari Dasha timeline mapping your life using the Mahadasha, Antardasha, and Pratyantardasha system. Know which planetary period you're in right now and what's coming next.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-purple-50 text-purple-500 px-2.5 py-1 rounded-full">Vimshottari Dasha</span>
            <span class="text-xs bg-purple-50 text-purple-500 px-2.5 py-1 rounded-full">Life Timeline</span>
          </div>
        </div>

        <!-- Remedies -->
        <div class="border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Remedies & Suggestions</h3>
          <p class="text-text-light text-sm leading-relaxed mb-3">
            Get personalized remedies for planetary afflictions.
          </p>
          <p class="text-text-light text-sm leading-relaxed">
            Receive gemstone recommendations, mantra suggestions, and practical Vedic remedies tailored to your specific chart and current Dasha period.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-green-50 text-green-600 px-2.5 py-1 rounded-full">Gemstones</span>
            <span class="text-xs bg-green-50 text-green-600 px-2.5 py-1 rounded-full">Mantras</span>
            <span class="text-xs bg-green-50 text-green-600 px-2.5 py-1 rounded-full">Personalized</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-bg-light">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Explore Your Stars?</h2>
      <p class="text-text-light mb-8">Start chatting with AstroBot on WhatsApp — no downloads, no sign-ups.</p>
      <a
        href="https://wa.me/919999999999?text=Hi%20AstroBot"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat with AstroBot Now
      </a>
    </div>
  </section>

</Layout>
