---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About - HoroTalk">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-primary">Home</a> &rsaquo; About
      </p>
      <h1 class="text-3xl md:text-5xl font-bold">About HoroTalk</h1>
      <p class="mt-4 text-text-light text-lg max-w-2xl">
        Making Vedic astrology accessible to everyone, one WhatsApp message at a time.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="prose prose-lg max-w-none">
        <h2 class="text-2xl font-bold mb-4">Our Mission</h2>
        <p class="text-text-light leading-relaxed mb-8">
          Millions of Indians consult astrologers for life's biggest decisions — career moves, marriage, health concerns, auspicious timings. But finding a reliable, knowledgeable astrologer is hard, expensive, and often inconvenient. HoroTalk changes that by putting a highly accurate, AI-powered Vedic astrologer right in your WhatsApp — available 24/7, in your language, at a fraction of the cost.
        </p>

        <h2 class="text-2xl font-bold mb-4">How We're Different</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="border border-border rounded-lg p-5">
            <h3 class="font-semibold mb-2">Traditional Astrologer</h3>
            <ul class="space-y-2 text-sm text-text-light">
              <li>Appointments & wait times</li>
              <li>Rs 500 - 5,000 per consultation</li>
              <li>Limited availability</li>
              <li>Varies in accuracy</li>
              <li>Manual calculations</li>
            </ul>
          </div>
          <div class="border-2 border-primary rounded-lg p-5 bg-primary-light">
            <h3 class="font-semibold text-primary mb-2">HoroTalk</h3>
            <ul class="space-y-2 text-sm text-text">
              <li>Instant responses, 24/7</li>
              <li>Starts free, Pro at Rs 99/month</li>
              <li>Always available on WhatsApp</li>
              <li>Swiss Ephemeris precision</li>
              <li>AI-powered with classical methods</li>
            </ul>
          </div>
        </div>

        <h2 class="text-2xl font-bold mb-4">The Technology</h2>
        <p class="text-text-light leading-relaxed mb-4">
          HoroTalk combines the precision of Swiss Ephemeris astronomical calculations with AI trained on classical Vedic astrology texts — Brihat Parashara Hora Shastra, Jataka Parijata, Phaladeepika, and more.
        </p>
        <p class="text-text-light leading-relaxed mb-8">
          Every reading is grounded in your actual birth chart — planetary positions, house lords, dashas, and yogas analyzed in real time. Not generic horoscopes based on sun signs.
        </p>

        <h2 class="text-2xl font-bold mb-4">Built in India, for India</h2>
        <p class="text-text-light leading-relaxed">
          HoroTalk is built with Indian users in mind. We support Hindi and English naturally, use the Vedic sidereal zodiac system by default, and understand the cultural context of Indian astrology — from mangal dosha to Sade Sati to muhurta selection.
        </p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-bg-light">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Try HoroTalk Today</h2>
      <p class="text-text-light mb-8">Send a message and get your first reading in under a minute.</p>
      <a
        href="https://wa.me/919999999999?text=Hi%20HoroTalk"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Chat with HoroTalk
      </a>
    </div>
  </section>

</Layout>
