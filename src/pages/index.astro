---
import Layout from '../layouts/Layout.astro';
import dailyData from '../data/daily-horoscope.json';

const signs = [
  { id: "aries", symbol: "\u2648", nameEn: "Mesha", subEn: "Aries", nameHi: "\u092E\u0947\u0937", subHi: "Aries" },
  { id: "taurus", symbol: "\u2649", nameEn: "Vrishabha", subEn: "Taurus", nameHi: "\u0935\u0943\u0937\u092D", subHi: "Taurus" },
  { id: "gemini", symbol: "\u264A", nameEn: "Mithuna", subEn: "Gemini", nameHi: "\u092E\u093F\u0925\u0941\u0928", subHi: "Gemini" },
  { id: "cancer", symbol: "\u264B", nameEn: "Karka", subEn: "Cancer", nameHi: "\u0915\u0930\u094D\u0915", subHi: "Cancer" },
  { id: "leo", symbol: "\u264C", nameEn: "Simha", subEn: "Leo", nameHi: "\u0938\u093F\u0902\u0939", subHi: "Leo" },
  { id: "virgo", symbol: "\u264D", nameEn: "Kanya", subEn: "Virgo", nameHi: "\u0915\u0928\u094D\u092F\u093E", subHi: "Virgo" },
  { id: "libra", symbol: "\u264E", nameEn: "Tula", subEn: "Libra", nameHi: "\u0924\u0941\u0932\u093E", subHi: "Libra" },
  { id: "scorpio", symbol: "\u264F", nameEn: "Vrishchika", subEn: "Scorpio", nameHi: "\u0935\u0943\u0936\u094D\u091A\u093F\u0915", subHi: "Scorpio" },
  { id: "sagittarius", symbol: "\u2650", nameEn: "Dhanu", subEn: "Sagittarius", nameHi: "\u0927\u0928\u0941", subHi: "Sagittarius" },
  { id: "capricorn", symbol: "\u2651", nameEn: "Makara", subEn: "Capricorn", nameHi: "\u092E\u0915\u0930", subHi: "Capricorn" },
  { id: "aquarius", symbol: "\u2652", nameEn: "Kumbha", subEn: "Aquarius", nameHi: "\u0915\u0941\u0902\u092D", subHi: "Aquarius" },
  { id: "pisces", symbol: "\u2653", nameEn: "Meena", subEn: "Pisces", nameHi: "\u092E\u0940\u0928", subHi: "Pisces" },
];
---

<Layout title="HoroTalk - Your Personal AI Astrologer on WhatsApp">

  <!-- Background Glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[500px] bg-[radial-gradient(circle_at_center,_#FF9933_0%,_transparent_70%)] opacity-[0.05] pointer-events-none"></div>

  <!-- Main Content Grid -->
  <div class="relative grid lg:grid-cols-[450px_1fr] gap-8 lg:gap-10 max-w-7xl mx-auto w-full px-4 sm:px-12 py-8 lg:py-10 items-start">

    <!-- Left Column: Hero -->
    <div class="flex flex-col gap-10 hero-animate">
      <section class="flex flex-col gap-6">
        <div class="flex flex-col gap-4 sm:gap-6 text-center lg:text-left">
          <h1 class="text-4xl sm:text-5xl lg:text-[48px] font-bold tracking-tight text-charcoal leading-[1.1]">
            <span id="hero-title">Your Vedic Edge for</span> <br class="hidden sm:block" />
            <span class="text-saffron italic" id="hero-title-italic">Life's Big Moves.</span>
          </h1>
          <p id="hero-sub" class="text-sm sm:text-base text-charcoal/70 leading-relaxed max-w-lg mx-auto lg:mx-0">
            Rooted in ancient wisdom. Designed for your modern journey. Get precise, personalized guidance from your AI Vedic astrologer — right on WhatsApp.
          </p>
        </div>
      </section>
    </div>

    <!-- Right Column: Guidance Panel -->
    <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-xl shadow-charcoal/5 flex flex-col gap-6 sm:gap-8 relative">

      <div class="flex flex-col sm:flex-row justify-between items-center sm:items-baseline gap-2">
        <h2 id="todays-light-title" class="text-lg sm:text-xl font-bold text-charcoal">Today's Light</h2>
        <span id="date-display" class="text-[10px] sm:text-[12px] opacity-50 font-bold uppercase tracking-widest"></span>
      </div>

      <!-- Zodiac Grid -->
      <div id="zodiac-grid" class="grid grid-cols-4 sm:grid-cols-6 gap-3 sm:gap-4">
        {signs.map((sign, i) => (
          <div
            class={`zodiac-sign flex flex-col items-center gap-2 cursor-pointer${i === 0 ? ' active' : ''}`}
            data-index={i}
            style={`animation-delay: ${i * 50}ms`}
          >
            <div class="zodiac-circle w-10 h-10 sm:w-11 sm:h-11 rounded-full border-[1.5px] flex items-center justify-center">
              <span class="zodiac-symbol text-base sm:text-lg leading-none">{sign.symbol}</span>
            </div>
            <span class="zodiac-label text-[8px] sm:text-[9px] font-bold uppercase tracking-wider text-center leading-tight">
              <span class="sign-name-top">{sign.nameEn}</span><br /><span class="sign-name-bottom">{sign.subEn}</span>
            </span>
          </div>
        ))}
      </div>

      <!-- Guidance Card -->
      <div id="guidance-card" class="bg-cream p-4 sm:p-5 rounded-2xl border-l-4 border-saffron min-h-[160px] flex flex-col justify-between">
        <div>
          <h4 id="guidance-sign-name" class="text-sm sm:text-base font-bold text-charcoal mb-2"></h4>
          <p id="guidance-text" class="text-xs sm:text-sm text-charcoal/80 leading-relaxed italic"></p>
        </div>
        <div class="mt-4 pt-4 border-t border-charcoal/5 flex items-center justify-between">
          <div id="success-prob-label" class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40">Success Probability</div>
          <div id="guidance-prob" class="text-lg font-bold text-saffron"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- WhatsApp CTA Section -->
  <section class="max-w-7xl mx-auto w-full px-4 sm:px-12 pb-12 sm:pb-20">
    <div class="scroll-animate bg-white p-6 sm:p-10 rounded-3xl border border-charcoal/5 shadow-xl shadow-charcoal/5 flex flex-col md:flex-row items-center justify-between gap-6 sm:gap-8 text-center md:text-left">
      <div class="max-w-xl">
        <h3 id="deeper-clarity" class="text-xl sm:text-2xl font-bold text-charcoal mb-2 sm:mb-3">
          Need Deeper Clarity? Get Tactical.
        </h3>
        <p id="whatsapp-sub" class="text-sm sm:text-base text-charcoal/60 leading-relaxed">
          Your generic sign is only 10% of the story. For the full 100% — including personal chart analysis, Dasha predictions, and your definitive guidance — chat with HoroTalk on WhatsApp.
        </p>
      </div>
      <a
        href="https://wa.me/919999999999?text=Hi%20HoroTalk"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full md:w-auto whitespace-nowrap bg-[#25D366] text-white px-8 sm:px-10 py-4 sm:py-5 rounded-full text-base sm:text-lg font-bold hover:bg-[#25D366]/90 transition-all shadow-xl shadow-[#25D366]/20 flex items-center justify-center gap-3 active:scale-95"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span id="get-analysis-text">Get Personalized Analysis</span>
      </a>
    </div>
  </section>

</Layout>

<style>
  /* Hero animation */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-animate {
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Zodiac grid stagger animation */
  .zodiac-sign {
    opacity: 0;
    animation: fadeScale 0.3s ease forwards;
  }
  @keyframes fadeScale {
    from { opacity: 0; transform: scale(0.9); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Zodiac icon default state */
  .zodiac-circle {
    border-color: rgba(255, 153, 51, 0.3);
    transition: all 0.3s;
  }
  .zodiac-symbol {
    color: rgba(255, 153, 51, 0.4);
    transition: color 0.3s;
    font-variant-emoji: text;
  }
  .zodiac-label {
    color: rgba(45, 45, 45, 0.4);
    transition: color 0.3s;
  }

  /* Zodiac hover */
  .zodiac-sign:hover .zodiac-circle {
    border-color: #FF9933;
    background-color: rgba(255, 153, 51, 0.05);
  }
  .zodiac-sign:hover .zodiac-symbol {
    color: #FF9933;
  }
  .zodiac-sign:hover .zodiac-label {
    color: #2D2D2D;
  }

  /* Zodiac active */
  .zodiac-sign.active .zodiac-circle {
    border-color: #FF9933;
    background-color: rgba(255, 153, 51, 0.1);
  }
  .zodiac-sign.active .zodiac-symbol {
    color: #FF9933;
  }
  .zodiac-sign.active .zodiac-label {
    color: #2D2D2D;
  }

  /* Guidance card transition */
  #guidance-card {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  /* Scroll animation */
  .scroll-animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .scroll-animate.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script is:inline define:vars={{ dailyJson: JSON.stringify(dailyData) }}>
  window.__dailyData = JSON.parse(dailyJson);
</script>

