  let currentLang = 'en';
  let selectedIndex = 0;

  function updateDate() {
    const el = document.getElementById('date-display');
    if (!el) return;
    const locale = currentLang === 'hi' ? 'hi-IN' : 'en-US';
    el.textContent = new Date().toLocaleDateString(locale, { month: 'long', day: 'numeric', year: 'numeric' });
  }

  function selectSign(index: number) {
    selectedIndex = index;

    document.querySelectorAll('.zodiac-sign').forEach((el, i) => {
      el.classList.toggle('active', i === index);
    });

    const card = document.getElementById('guidance-card');
    if (!card) return;

    card.style.opacity = '0';
    card.style.transform = 'translateX(20px)';

    setTimeout(() => {
      const sign = signsData[index];
      const t = uiText[currentLang];
      const nameEl = document.getElementById('guidance-sign-name');
      const textEl = document.getElementById('guidance-text');
      const probEl = document.getElementById('guidance-prob');

      if (nameEl) nameEl.textContent = sign.name[currentLang] + ' \u2014 ' + t.todaysLight;
      if (textEl) textEl.textContent = '\u201C' + sign.guidance[currentLang] + '\u201D';
      if (probEl) probEl.textContent = sign.probability + '%';

      card.style.transform = 'translateX(-20px)';
      requestAnimationFrame(() => {
        card.style.opacity = '1';
        card.style.transform = 'translateX(0)';
      });
    }, 200);
  }

  function updateLanguage(lang: string) {
    currentLang = lang;
    const t = uiText[lang];

    const updates: Record<string, string> = {
      'hero-title': t.heroTitle,
      'hero-title-italic': t.heroTitleItalic,
      'hero-sub': t.heroSub,
      'todays-light-title': t.todaysLight,
      'success-prob-label': t.successProb,
      'deeper-clarity': t.deeperClarity,
      'whatsapp-sub': t.whatsappSub,
      'get-analysis-text': t.getAnalysis,
      'header-chat-text': t.chatNow
    };

    for (const [id, text] of Object.entries(updates)) {
      const el = document.getElementById(id);
      if (el) el.textContent = text;
    }

    document.querySelectorAll('.zodiac-sign').forEach((el, i) => {
      const sign = signsData[i];
      const topEl = el.querySelector('.sign-name-top');
      const bottomEl = el.querySelector('.sign-name-bottom');
      if (topEl) topEl.textContent = sign.nameTop[lang];
      if (bottomEl) bottomEl.textContent = sign.name[lang].split(' / ')[1];
    });

    const sign = signsData[selectedIndex];
    const nameEl = document.getElementById('guidance-sign-name');
    const textEl = document.getElementById('guidance-text');
    if (nameEl) nameEl.textContent = sign.name[lang] + ' \u2014 ' + t.todaysLight;
    if (textEl) textEl.textContent = '\u201C' + sign.guidance[lang] + '\u201D';

    updateDate();
  }

  // Initialize
  updateDate();
  selectSign(0);

  document.querySelectorAll('.zodiac-sign').forEach(el => {
    el.addEventListener('click', () => {
      const idx = parseInt((el as HTMLElement).dataset.index || '0');
      selectSign(idx);
    });
  });

  window.addEventListener('lang-change', ((e: CustomEvent) => {
    updateLanguage(e.detail.lang);
  }) as EventListener);

  // Scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.scroll-animate').forEach(el => observer.observe(el));
</script>
