const faqs = [
  { q: { en: "What is Janam Kundli and why does it matter?", hi: "\u091C\u0928\u094D\u092E \u0915\u0941\u0902\u0921\u0932\u0940 \u0915\u094D\u092F\u093E \u0939\u0948 \u0914\u0930 \u092F\u0939 \u092E\u0939\u0924\u094D\u0935\u092A\u0942\u0930\u094D\u0923 \u0915\u094D\u092F\u094B\u0902 \u0939\u0948?" }, a: { en: "Your Janam Kundli is a map of the sky at the exact moment you were born. It records the positions of all nine planets across 12 houses, each governing a different area of your life. From career timing to relationship compatibility, your Kundli holds the blueprint. HoroTalk calculates it using degree-level planetary data, not generic tables, so every chart is unique to you.", hi: "\u091C\u0928\u094D\u092E \u0915\u0941\u0902\u0921\u0932\u0940 \u0906\u092A\u0915\u0947 \u091C\u0928\u094D\u092E \u0915\u0947 \u0938\u092E\u092F \u0906\u0915\u093E\u0936 \u0915\u093E \u0928\u0915\u094D\u0936\u093E \u0939\u0948\u0964 \u092F\u0939 \u0928\u094C \u0917\u094D\u0930\u0939\u094B\u0902 \u0915\u0940 12 \u092D\u093E\u0935\u094B\u0902 \u092E\u0947\u0902 \u0938\u094D\u0925\u093F\u0924\u093F \u0926\u0930\u094D\u091C \u0915\u0930\u0924\u0940 \u0939\u0948\u0964 \u0915\u0930\u093F\u092F\u0930 \u0938\u0947 \u0930\u093F\u0936\u094D\u0924\u094B\u0902 \u0924\u0915, \u0938\u092C \u0915\u0941\u091B \u0907\u0938\u092E\u0947\u0902 \u091B\u093F\u092A\u093E \u0939\u0948\u0964 HoroTalk \u0921\u093F\u0917\u094D\u0930\u0940-\u0938\u094D\u0924\u0930 \u0915\u0940 \u0917\u0923\u0928\u093E \u0915\u0930\u0924\u093E \u0939\u0948, \u0907\u0938\u0932\u093F\u090F \u0939\u0930 \u0915\u0941\u0902\u0921\u0932\u0940 \u0905\u0928\u0942\u0920\u0940 \u0939\u094B\u0924\u0940 \u0939\u0948\u0964" } },
  { q: { en: "How does HoroTalk calculate my birth chart?", hi: "HoroTalk \u092E\u0947\u0930\u0940 \u0915\u0941\u0902\u0921\u0932\u0940 \u0915\u0948\u0938\u0947 \u092C\u0928\u093E\u0924\u093E \u0939\u0948?" }, a: { en: "HoroTalk uses Swiss Ephemeris-grade astronomical algorithms to compute the exact longitude of each planet at your birth time. We apply the Lahiri ayanamsa to convert tropical positions to the Vedic sidereal zodiac. This is the same method used by professional Vedic astrologers, but delivered in seconds through AI trained on classical texts like Brihat Parashara Hora Shastra and Phaladeepika.", hi: "HoroTalk Swiss Ephemeris \u0938\u094D\u0924\u0930 \u0915\u0947 \u0916\u0917\u094B\u0932\u0940\u092F \u090F\u0932\u094D\u0917\u094B\u0930\u093F\u0926\u092E \u0938\u0947 \u0939\u0930 \u0917\u094D\u0930\u0939 \u0915\u0940 \u0938\u091F\u0940\u0915 \u0938\u094D\u0925\u093F\u0924\u093F \u0917\u0923\u0928\u093E \u0915\u0930\u0924\u093E \u0939\u0948\u0964 \u0932\u093E\u0939\u093F\u0930\u0940 \u0905\u092F\u0928\u093E\u0902\u0936 \u0932\u093E\u0917\u0942 \u0915\u0930 \u0935\u0948\u0926\u093F\u0915 \u0938\u093E\u092F\u0928 \u0930\u093E\u0936\u093F\u091A\u0915\u094D\u0930 \u092E\u0947\u0902 \u092C\u0926\u0932\u093E \u091C\u093E\u0924\u093E \u0939\u0948\u0964 \u092F\u0939\u0940 \u0924\u0930\u0940\u0915\u093E \u092A\u0947\u0936\u0947\u0935\u0930 \u091C\u094D\u092F\u094B\u0924\u093F\u0937\u0940 \u0909\u092A\u092F\u094B\u0917 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902\u0964" } },
  { q: { en: "What is the difference between Vedic and Western astrology?", hi: "\u0935\u0948\u0926\u093F\u0915 \u0914\u0930 \u092A\u0936\u094D\u091A\u093F\u092E\u0940 \u091C\u094D\u092F\u094B\u0924\u093F\u0937 \u092E\u0947\u0902 \u0915\u094D\u092F\u093E \u0905\u0902\u0924\u0930 \u0939\u0948?" }, a: { en: "Vedic astrology (Jyotish) uses the sidereal zodiac, which tracks the actual positions of stars as they appear in the sky today. Western astrology uses the tropical zodiac, which is based on the seasons and has drifted roughly 24 degrees from the real star positions over centuries. Vedic astrology also includes the Vimshottari Dasha system, a powerful timing tool that maps which planet rules each phase of your life. This is why Vedic readings tend to be more specific about when events will unfold.", hi: "\u0935\u0948\u0926\u093F\u0915 \u091C\u094D\u092F\u094B\u0924\u093F\u0937 \u0924\u093E\u0930\u094B\u0902 \u0915\u0940 \u0935\u093E\u0938\u094D\u0924\u0935\u093F\u0915 \u0938\u094D\u0925\u093F\u0924\u093F \u092A\u0930 \u0906\u0927\u093E\u0930\u093F\u0924 \u0939\u0948\u0964 \u092A\u0936\u094D\u091A\u093F\u092E\u0940 \u091C\u094D\u092F\u094B\u0924\u093F\u0937 \u092E\u094C\u0938\u092E\u094B\u0902 \u092A\u0930 \u0906\u0927\u093E\u0930\u093F\u0924 \u0939\u0948 \u0914\u0930 \u0938\u0926\u093F\u092F\u094B\u0902 \u092E\u0947\u0902 \u0932\u0917\u092D\u0917 24 \u0905\u0902\u0936 \u0916\u093F\u0938\u0915 \u0917\u0908 \u0939\u0948\u0964 \u0935\u0948\u0926\u093F\u0915 \u092E\u0947\u0902 \u0935\u093F\u092E\u094D\u0936\u094B\u0924\u094D\u0924\u0930\u0940 \u0926\u0936\u093E \u092A\u094D\u0930\u0923\u093E\u0932\u0940 \u092D\u0940 \u0939\u0948 \u091C\u094B \u092C\u0924\u093E\u0924\u0940 \u0939\u0948 \u0915\u093F \u0918\u091F\u0928\u093E\u090F\u0902 \u0915\u092C \u0939\u094B\u0902\u0917\u0940\u0964" } },
  { q: { en: "How does Kundli matching work for marriage?", hi: "\u0935\u093F\u0935\u093E\u0939 \u0915\u0947 \u0932\u093F\u090F \u0915\u0941\u0902\u0921\u0932\u0940 \u092E\u093F\u0932\u093E\u0928 \u0915\u0948\u0938\u0947 \u0915\u093E\u092E \u0915\u0930\u0924\u093E \u0939\u0948?" }, a: { en: "Kundli matching uses the Ashtakoot Guna Milan system to compare two birth charts across 36 points in eight categories: temperament (Varna), physical compatibility (Vashya), birth star harmony (Tara), species (Yoni), planetary friendship (Graha Maitri), offspring (Gana), health and longevity (Bhakoot), and mental compatibility (Nadi). A score above 18 out of 36 is considered favorable. HoroTalk also checks for Manglik dosha and other specific compatibility factors.", hi: "\u0915\u0941\u0902\u0921\u0932\u0940 \u092E\u093F\u0932\u093E\u0928 \u0905\u0937\u094D\u091F\u0915\u0942\u091F \u0917\u0941\u0923 \u092E\u093F\u0932\u093E\u0928 \u092A\u094D\u0930\u0923\u093E\u0932\u0940 \u0938\u0947 \u0906\u0920 \u0936\u094D\u0930\u0947\u0923\u093F\u092F\u094B\u0902 \u092E\u0947\u0902 36 \u0917\u0941\u0923\u094B\u0902 \u0915\u0940 \u0924\u0941\u0932\u0928\u093E \u0915\u0930\u0924\u093E \u0939\u0948: \u0935\u0930\u094D\u0923, \u0935\u0936\u094D\u092F, \u0924\u093E\u0930\u093E, \u092F\u094B\u0928\u093F, \u0917\u094D\u0930\u0939 \u092E\u0948\u0924\u094D\u0930\u0940, \u0917\u0923, \u092D\u0915\u0942\u091F \u0914\u0930 \u0928\u093E\u0921\u0940\u0964 36 \u092E\u0947\u0902 \u0938\u0947 18 \u0938\u0947 \u0905\u0927\u093F\u0915 \u0905\u0902\u0915 \u0936\u0941\u092D \u092E\u093E\u0928\u093E \u091C\u093E\u0924\u093E \u0939\u0948\u0964 HoroTalk \u092E\u093E\u0902\u0917\u0932\u093F\u0915 \u0926\u094B\u0937 \u0915\u0940 \u092D\u0940 \u091C\u093E\u0902\u091A \u0915\u0930\u0924\u093E \u0939\u0948\u0964" } },
  { q: { en: "What is Dasha and how does it affect my life?", hi: "\u0926\u0936\u093E \u0915\u094D\u092F\u093E \u0939\u0948 \u0914\u0930 \u092F\u0939 \u092E\u0947\u0930\u0947 \u091C\u0940\u0935\u0928 \u0915\u094B \u0915\u0948\u0938\u0947 \u092A\u094D\u0930\u092D\u093E\u0935\u093F\u0924 \u0915\u0930\u0924\u0940 \u0939\u0948?" }, a: { en: "Dasha is Vedic astrology's timing system. The Vimshottari Dasha divides your life into planetary periods. Each Mahadasha (major period) lasts 6 to 20 years and is ruled by a specific planet. Within each Mahadasha are Antardashas (sub-periods) that create more specific timing windows. Knowing your current Dasha helps you understand why certain themes dominate your life right now and when shifts will come. For example, Saturn Mahadasha emphasizes discipline and career growth, while Venus Mahadasha brings relationships and comfort into focus.", hi: "\u0926\u0936\u093E \u0935\u0948\u0926\u093F\u0915 \u091C\u094D\u092F\u094B\u0924\u093F\u0937 \u0915\u0940 \u0938\u092E\u092F \u092A\u094D\u0930\u0923\u093E\u0932\u0940 \u0939\u0948\u0964 \u0935\u093F\u092E\u094D\u0936\u094B\u0924\u094D\u0924\u0930\u0940 \u0926\u0936\u093E \u0906\u092A\u0915\u0947 \u091C\u0940\u0935\u0928 \u0915\u094B \u0917\u094D\u0930\u0939 \u0915\u093E\u0932 \u092E\u0947\u0902 \u092C\u093E\u0902\u091F\u0924\u0940 \u0939\u0948\u0964 \u0939\u0930 \u092E\u0939\u093E\u0926\u0936\u093E 6 \u0938\u0947 20 \u0938\u093E\u0932 \u091A\u0932\u0924\u0940 \u0939\u0948\u0964 \u0905\u092A\u0928\u0940 \u0935\u0930\u094D\u0924\u092E\u093E\u0928 \u0926\u0936\u093E \u091C\u093E\u0928\u0928\u0947 \u0938\u0947 \u0906\u092A \u0938\u092E\u091D \u0938\u0915\u0924\u0947 \u0939\u0948\u0902 \u0915\u093F \u091C\u0940\u0935\u0928 \u092E\u0947\u0902 \u092C\u0926\u0932\u093E\u0935 \u0915\u092C \u0914\u0930 \u0915\u0948\u0938\u0947 \u0906\u090F\u0917\u093E\u0964" } },
  { q: { en: "Is AI-powered Vedic astrology reliable?", hi: "\u0915\u094D\u092F\u093E AI \u0935\u0948\u0926\u093F\u0915 \u091C\u094D\u092F\u094B\u0924\u093F\u0937 \u092D\u0930\u094B\u0938\u0947\u092E\u0902\u0926 \u0939\u0948?" }, a: { en: "The astronomical calculations behind your chart are mathematically precise. HoroTalk computes real planetary longitudes, applies the Lahiri ayanamsa, and generates Lagna, Navamsa, and divisional charts from actual data. The AI interprets these charts using principles from classical texts like Brihat Parashara Hora Shastra, Jataka Parijata, and Phaladeepika. The result is a reading grounded in the same tradition that Vedic astrologers have followed for thousands of years, made accessible instantly through WhatsApp.", hi: "\u0906\u092A\u0915\u0940 \u0915\u0941\u0902\u0921\u0932\u0940 \u0915\u0940 \u0916\u0917\u094B\u0932\u0940\u092F \u0917\u0923\u0928\u093E\u090F\u0902 \u0917\u0923\u093F\u0924\u0940\u092F \u0930\u0942\u092A \u0938\u0947 \u0938\u091F\u0940\u0915 \u0939\u0948\u0902\u0964 HoroTalk \u0935\u093E\u0938\u094D\u0924\u0935\u093F\u0915 \u0917\u094D\u0930\u0939 \u0938\u094D\u0925\u093F\u0924\u093F, \u0932\u093E\u0939\u093F\u0930\u0940 \u0905\u092F\u0928\u093E\u0902\u0936, \u0914\u0930 \u0932\u0917\u094D\u0928, \u0928\u0935\u093E\u0902\u0936 \u091A\u093E\u0930\u094D\u091F \u092C\u0928\u093E\u0924\u093E \u0939\u0948\u0964 AI \u092C\u0943\u0939\u0924 \u092A\u0930\u093E\u0936\u0930 \u0939\u094B\u0930\u093E \u0936\u093E\u0938\u094D\u0924\u094D\u0930 \u091C\u0948\u0938\u0947 \u0936\u093E\u0938\u094D\u0924\u094D\u0930\u0940\u092F \u0917\u094D\u0930\u0902\u0925\u094B\u0902 \u0915\u0947 \u0938\u093F\u0926\u094D\u0927\u093E\u0902\u0924\u094B\u0902 \u0938\u0947 \u0935\u094D\u092F\u093E\u0916\u094D\u092F\u093E \u0915\u0930\u0924\u093E \u0939\u0948\u0964 \u092F\u0939 \u0935\u0939\u0940 \u092A\u0930\u0902\u092A\u0930\u093E \u0939\u0948 \u091C\u094B \u0939\u091C\u093E\u0930\u094B\u0902 \u0938\u093E\u0932\u094B\u0902 \u0938\u0947 \u091A\u0932\u0940 \u0906 \u0930\u0939\u0940 \u0939\u0948\u0964" } },
];

