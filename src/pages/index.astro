---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AstroBot - Your Personal AI Astrologer on WhatsApp">

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-white via-primary-light to-white">
    <!-- Background decoration -->
    <div class="absolute inset-0 opacity-5">
      <svg class="w-full h-full" viewBox="0 0 800 600" fill="none">
        <circle cx="400" cy="300" r="200" stroke="#EA580C" stroke-width="1"/>
        <circle cx="400" cy="300" r="150" stroke="#EA580C" stroke-width="0.5"/>
        <circle cx="400" cy="300" r="100" stroke="#EA580C" stroke-width="0.5"/>
        <line x1="200" y1="300" x2="600" y2="300" stroke="#EA580C" stroke-width="0.5"/>
        <line x1="400" y1="100" x2="400" y2="500" stroke="#EA580C" stroke-width="0.5"/>
        <line x1="259" y1="159" x2="541" y2="441" stroke="#EA580C" stroke-width="0.5"/>
        <line x1="541" y1="159" x2="259" y2="441" stroke="#EA580C" stroke-width="0.5"/>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight">
          Read your<br/>
          <span class="text-primary">Future with AI</span><br/>
          Astrologer
        </h1>
        <p class="mt-4 text-text-light text-lg">
          AI ज्योतिषी से अपने प्रश्न पूछें
        </p>
        <p class="mt-2 text-text-light text-base md:text-lg max-w-xl">
          WhatsApp-based AI Astrologer that gives you personalized Vedic readings and answers to your questions based on your kundli.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="https://wa.me/919999999999?text=Hi%20AstroBot"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors text-base"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Chat Now
          </a>
          <a
            href="/features"
            class="inline-flex items-center gap-2 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold px-6 py-3 rounded-lg transition-colors text-base"
          >
            Learn More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Overview -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold">Everything You Need for<br/>Astrology Readings</h2>
        <p class="mt-4 text-text-light max-w-2xl mx-auto">
          AstroBot combines AI-powered astrology with traditional Vedic systems — right inside your WhatsApp. No app to download.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-white border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">AI Astrology Chat</h3>
          <p class="text-text-light text-sm leading-relaxed">
            Ask any astrology question and get instant, personalized answers. Chat with an AI Vedic astrologer that understands your birth chart.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">Hindi & English</span>
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">24/7 Available</span>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Birth Chart (Kundli)</h3>
          <p class="text-text-light text-sm leading-relaxed">
            Generate your complete Kundli with accurate planetary positions, house placements, and divisional charts. North & South Indian styles.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">Vedic Charts</span>
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">Precise Calculations</span>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white border border-border rounded-xl p-6 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Daily Panchang</h3>
          <p class="text-text-light text-sm leading-relaxed">
            Know today's tithi, nakshatra, yoga, and auspicious timings. Get Choghadiya, Rahu Kaal, and muhurta for any date and location.
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">Daily Updates</span>
            <span class="text-xs bg-primary-light text-primary px-2 py-1 rounded-full">Location Based</span>
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="/features" class="text-primary hover:text-primary-dark font-medium inline-flex items-center gap-1">
          View all features
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose AstroBot -->
  <section class="py-16 md:py-24 bg-bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Why Choose AstroBot?</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-14 h-14 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Accurate Calculations</h3>
          <p class="text-text-light text-sm">Built on Swiss Ephemeris — the same engine used by professional astrologers worldwide. Degree-level precision.</p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Instant on WhatsApp</h3>
          <p class="text-text-light text-sm">No app to download. No sign-up forms. Just send a message on WhatsApp and get your reading in seconds.</p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Hindi & English</h3>
          <p class="text-text-light text-sm">Chat in the language you're comfortable with. AstroBot understands both Hindi and English naturally.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">How It Works</h2>
      <p class="text-text-light text-center mb-12 max-w-xl mx-auto">Get your personalized astrology reading in 3 simple steps</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
          <h3 class="text-lg font-semibold mb-2">Send "Hi" on WhatsApp</h3>
          <p class="text-text-light text-sm">Tap the Chat Now button and send a message to AstroBot on WhatsApp. No sign-up needed.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
          <h3 class="text-lg font-semibold mb-2">Share Your Birth Details</h3>
          <p class="text-text-light text-sm">Tell AstroBot your date, time, and place of birth. It generates your Kundli instantly.</p>
        </div>

        <div class="text-center">
          <div class="w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
          <h3 class="text-lg font-semibold mb-2">Ask Anything</h3>
          <p class="text-text-light text-sm">Ask about career, relationships, health, finances — get personalized answers rooted in your unique planetary positions.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a
          href="https://wa.me/919999999999?text=Hi%20AstroBot"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Start Chatting — It's Free
        </a>
      </div>
    </div>
  </section>

</Layout>
