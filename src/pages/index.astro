  function pick(i:number){sel=i;document.querySelectorAll('.zodiac-sign').forEach((e,j)=>e.classList.toggle('active',j===i));const c=document.getElementById('guidance-card');if(!c)return;c.style.opacity='0';c.style.transform='translateX(10px)';setTimeout(()=>{const s=signsData[i],t=ui[lang];
