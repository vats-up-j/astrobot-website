---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pricing - HoroTalk">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-primary">Home</a> &rsaquo; Pricing
      </p>
      <h1 class="text-3xl md:text-5xl font-bold">Simple, Transparent Pricing</h1>
      <p class="mt-4 text-text-light text-lg max-w-2xl">
        Start free. Upgrade when you need more. No hidden charges.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <!-- Free Tier -->
        <div class="border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
          <h3 class="text-lg font-semibold text-text-light mb-1">Free</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold">&#8377;0</span>
            <span class="text-text-light text-sm">/ forever</span>
          </div>
          <p class="text-text-light text-sm mb-6">Perfect to explore and try HoroTalk</p>
          <a
            href="https://wa.me/919999999999?text=Hi%20HoroTalk"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold py-3 rounded-lg transition-colors text-sm"
          >
            Get Started Free
          </a>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              5 questions per day
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Basic Kundli generation
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Daily Panchang
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Hindi & English
            </li>
          </ul>
        </div>

        <!-- Pro Tier -->
        <div class="border-2 border-primary rounded-xl p-8 relative shadow-lg">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">Most Popular</div>
          <h3 class="text-lg font-semibold text-primary mb-1">Pro</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold">&#8377;99</span>
            <span class="text-text-light text-sm">/ month</span>
          </div>
          <p class="text-text-light text-sm mb-6">For regular users who want deeper insights</p>
          <a
            href="https://wa.me/919999999999?text=I%20want%20to%20upgrade%20to%20Pro"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center bg-primary hover:bg-primary-dark text-white font-semibold py-3 rounded-lg transition-colors text-sm"
          >
            Upgrade to Pro
          </a>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Unlimited questions
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Detailed Kundli with divisional charts
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Dasha predictions & timeline
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Kundli matching
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Personalized remedies
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Priority responses
            </li>
          </ul>
        </div>

        <!-- Premium Tier -->
        <div class="border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
          <h3 class="text-lg font-semibold text-text-light mb-1">Premium</h3>
          <div class="flex items-baseline gap-1 mb-4">
            <span class="text-4xl font-bold">&#8377;299</span>
            <span class="text-text-light text-sm">/ month</span>
          </div>
          <p class="text-text-light text-sm mb-6">For serious seekers & professionals</p>
          <a
            href="https://wa.me/919999999999?text=I%20want%20to%20upgrade%20to%20Premium"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold py-3 rounded-lg transition-colors text-sm"
          >
            Go Premium
          </a>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Everything in Pro
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Detailed PDF reports
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Yearly predictions
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Transit analysis
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Family charts (up to 5 members)
            </li>
            <li class="flex items-start gap-2 text-sm text-text-light">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              Muhurta consultation
            </li>
          </ul>
        </div>

      </div>

      <!-- FAQ -->
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
        <div class="max-w-2xl mx-auto space-y-6">
          <div>
            <h3 class="font-semibold mb-1">How do I pay?</h3>
            <p class="text-text-light text-sm">Simply message HoroTalk on WhatsApp that you'd like to upgrade. We'll send you a UPI payment link — quick and easy.</p>
          </div>
          <div>
            <h3 class="font-semibold mb-1">Can I cancel anytime?</h3>
            <p class="text-text-light text-sm">Yes, absolutely. No lock-in period. Just message us and we'll cancel your subscription.</p>
          </div>
          <div>
            <h3 class="font-semibold mb-1">Is my data safe?</h3>
            <p class="text-text-light text-sm">We only store your birth details to generate readings. We never share your data with third parties.</p>
          </div>
          <div>
            <h3 class="font-semibold mb-1">What if I'm not satisfied?</h3>
            <p class="text-text-light text-sm">We offer a 7-day money-back guarantee on all paid plans. No questions asked.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>
