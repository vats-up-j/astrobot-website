      <div class="grid grid-cols-3 gap-3 mb-10">
        <div class="bg-white rounded-xl p-5 shadow-sm border border-charcoal/5 text-center hover:border-gold/30 hover:shadow-md transition-all">
          <div class="text-2xl font-bold text-charcoal font-heading">&#8377;99</div>
          <div class="text-xs text-charcoal/40 mt-1 i18n" data-en="Starter" data-hi="&#x0938;&#x094D;&#x091F;&#x093E;&#x0930;&#x094D;&#x091F;&#x0930;">Starter</div>
