    { symbol: '\u264A', id: 'gemini', name: { en: 'Mithuna (Gemini)', hi: 'मिथुन' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Mercury (Budh)', hi: 'बुध' }, lucky: { num: 5, color: { en: 'Yellow', hi: 'पीला' } }, compatible: { en: 'Libra, Aquarius', hi: 'तुला, कुंभ' }, traits: { en: 'Curious, adaptable, witty, sociable, expressive', hi: 'जिज्ञासु, अनुकूलनीय, हाजिरजवाब, मिलनसार, अभिव्यक्तिशील' } },
    { symbol: '\u264B', id: 'cancer', name: { en: 'Karka (Cancer)', hi: 'कर्क' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Moon (Chandra)', hi: 'चंद्रमा' }, lucky: { num: 2, color: { en: 'White', hi: 'सफेद' } }, compatible: { en: 'Scorpio, Pisces', hi: 'वृश्चिक, मीन' }, traits: { en: 'Nurturing, intuitive, protective, emotional, loyal', hi: 'पालनकर्ता, सहज ज्ञानी, सुरक्षात्मक, भावनात्मक, वफादार' } },
