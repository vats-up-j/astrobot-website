    { symbol: '\u264D', id: 'virgo', name: { en: 'Kanya (Virgo)', hi: 'कन्या' }, element: { en: 'Earth', hi: 'पृथ्वी' }, ruler: { en: 'Mercury (Budh)', hi: 'बुध' }, lucky: { num: 5, color: { en: 'Green', hi: 'हरा' } }, compatible: { en: 'Taurus, Capricorn', hi: 'वृषभ, मकर' }, traits: { en: 'Analytical, meticulous, reliable, modest, practical', hi: 'विश्लेषणात्मक, सावधान, विश्वसनीय, विनम्र, व्यावहारिक' } },
    { symbol: '\u264E', id: 'libra', name: { en: 'Tula (Libra)', hi: 'तुला' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Venus (Shukra)', hi: 'शुक्र' }, lucky: { num: 6, color: { en: 'Blue', hi: 'नीला' } }, compatible: { en: 'Gemini, Aquarius', hi: 'मिथुन, कुंभ' }, traits: { en: 'Diplomatic, fair-minded, social, graceful, balanced', hi: 'कूटनीतिक, न्यायप्रिय, सामाजिक, शालीन, संतुलित' } },
    { symbol: '\u264F', id: 'scorpio', name: { en: 'Vrishchika (Scorpio)', hi: 'वृश्चिक' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Mars (Mangal)', hi: 'मंगल' }, lucky: { num: 9, color: { en: 'Maroon', hi: 'गहरा लाल' } }, compatible: { en: 'Cancer, Pisces', hi: 'कर्क, मीन' }, traits: { en: 'Intense, resourceful, brave, passionate, strategic', hi: 'तीव्र, साधनसंपन्न, बहादुर, जुनूनी, रणनीतिक' } },
    { symbol: '\u2650', id: 'sagittarius', name: { en: 'Dhanu (Sagittarius)', hi: 'धनु' }, element: { en: 'Fire', hi: 'अग्नि' }, ruler: { en: 'Jupiter (Guru)', hi: 'बृहस्पति' }, lucky: { num: 3, color: { en: 'Purple', hi: 'बैंगनी' } }, compatible: { en: 'Aries, Leo', hi: 'मेष, सिंह' }, traits: { en: 'Optimistic, adventurous, generous, philosophical, honest', hi: 'आशावादी, साहसी, उदार, दार्शनिक, ईमानदार' } },
    { symbol: '\u2651', id: 'capricorn', name: { en: 'Makara (Capricorn)', hi: 'मकर' }, element: { en: 'Earth', hi: 'पृथ्वी' }, ruler: { en: 'Saturn (Shani)', hi: 'शनि' }, lucky: { num: 8, color: { en: 'Brown', hi: 'भूरा' } }, compatible: { en: 'Taurus, Virgo', hi: 'वृषभ, कन्या' }, traits: { en: 'Disciplined, responsible, ambitious, patient, practical', hi: 'अनुशासित, जिम्मेदार, महत्वाकांक्षी, धैर्यवान, व्यावहारिक' } },
    { symbol: '\u2652', id: 'aquarius', name: { en: 'Kumbha (Aquarius)', hi: 'कुंभ' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Saturn (Shani)', hi: 'शनि' }, lucky: { num: 8, color: { en: 'Sky Blue', hi: 'आसमानी' } }, compatible: { en: 'Gemini, Libra', hi: 'मिथुन, तुला' }, traits: { en: 'Innovative, independent, humanitarian, visionary, original', hi: 'नवप्रवर्तक, स्वतंत्र, मानवतावादी, दूरदर्शी, मौलिक' } },
    { symbol: '\u2653', id: 'pisces', name: { en: 'Meena (Pisces)', hi: 'मीन' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Jupiter (Guru)', hi: 'बृहस्पति' }, lucky: { num: 3, color: { en: 'Sea Green', hi: 'समुद्री हरा' } }, compatible: { en: 'Cancer, Scorpio', hi: 'कर्क, वृश्चिक' }, traits: { en: 'Compassionate, artistic, intuitive, gentle, wise', hi: 'दयालु, कलात्मक, सहज ज्ञानी, कोमल, बुद्धिमान' } },
  ];

  const syllableMap: Record<string, number> = {
    'chu':0,'che':0,'cho':0,'la':0,'li':0,'lu':0,'le':0,'lo':0,
    'va':1,'vi':1,'vu':1,'ve':1,'vo':1,'ba':1,'bi':1,'bu':1,'be':1,'bo':1,'wa':1,'wi':1,'wu':1,'we':1,'wo':1,
    'ka':2,'ki':2,'ku':2,'ke':2,'ko':2,'gha':2,'ha':2,
    'hi':3,'hu':3,'he':3,'ho':3,'da':3,'di':3,'du':3,'de':3,'do':3,
    'ma':4,'mi':4,'mu':4,'me':4,'mo':4,'ta':4,'ti':4,'tu':4,'te':4,
    'to':5,'pa':5,'pi':5,'pu':5,'sha':5,'shi':5,'shu':5,'she':5,'sho':5,'tha':5,'pe':5,'po':5,
    'ra':6,'ri':6,'ru':6,'re':6,'ro':6,
    'na':7,'ni':7,'nu':7,'ne':7,'no':7,'ya':7,'yi':7,'yu':7,
    'ye':8,'yo':8,'bha':8,'bhi':8,'bhu':8,'bhe':8,'dha':8,'dhi':8,'dhu':8,'pha':8,'phi':8,'phu':8,'fa':8,'fi':8,'fu':8,'bho':8,
    'ja':9,'ji':9,'ju':9,'je':9,'jo':9,'kha':9,'khi':9,'khu':9,'khe':9,'kho':9,
    'ga':10,'gi':10,'gu':10,'ge':10,'go':10,'sa':10,'si':10,'su':10,'se':10,'so':10,
    'cha':11,'chi':11,'jha':11,
  };

  const devanagariMap: Record<string, number> = {
    'अ':0,'आ':0,'ल':0,'इ':1,'ई':1,'उ':1,'ऊ':1,'ए':1,'ऐ':1,'ओ':1,'औ':1,'ब':1,'व':1,
    'क':2,'छ':2,'घ':2,'ह':2,'ड':3,'ढ':3,'म':4,'ट':4,'प':5,'ठ':5,'ण':5,'श':5,'ष':5,
    'र':6,'त':6,'न':7,'य':7,'भ':8,'ध':8,'फ':8,'ज':9,'ख':9,'ग':10,'स':10,'च':11,'द':11,'थ':11,'झ':11,
  };

  function findRashi(name: string): number | null {
    const t = name.trim(); if (!t) return null;
    const fc = t.charAt(0);
    if (/[\u0900-\u097F]/.test(fc)) {
      const base = fc.normalize('NFD').charAt(0);
      if (devanagariMap[base] !== undefined) return devanagariMap[base];
      if (devanagariMap[fc] !== undefined) return devanagariMap[fc];
      return null;
    }
    const lw = t.toLowerCase();
    for (const len of [3, 2]) { const s = lw.substring(0, len); if (syllableMap[s] !== undefined) return syllableMap[s]; }
    const f = lw.charAt(0);
    if (f === 'a') return 0;
    if ('ieou'.includes(f)) return 1;
    return null;
  }

  let currentLang = 'en';

  function showResult(idx: number) {
    const r = rashiData[idx]; const lang = currentLang as 'en' | 'hi';
    (document.getElementById('result-symbol') as HTMLElement).textContent = r.symbol;
    (document.getElementById('result-name') as HTMLElement).textContent = r.name[lang];
    (document.getElementById('result-element') as HTMLElement).textContent = r.element[lang];
    (document.getElementById('result-ruler') as HTMLElement).textContent = r.ruler[lang];
    (document.getElementById('result-compatible') as HTMLElement).textContent = r.compatible[lang];
    (document.getElementById('result-lucky-num') as HTMLElement).textContent = String(r.lucky.num);
    (document.getElementById('result-lucky-color') as HTMLElement).textContent = r.lucky.color[lang];
    (document.getElementById('result-traits') as HTMLElement).textContent = r.traits[lang];

    // Show today's horoscope for this sign
    const daily = (window as any).__dailySigns;
    const signData = daily?.find((s: any) => s.id === r.id);
    const horoEl = document.getElementById('result-horoscope-text');
    if (horoEl && signData) horoEl.textContent = signData.guidance[lang];

    (document.getElementById('result-card') as HTMLElement).classList.remove('hidden');
    (document.getElementById('error-msg') as HTMLElement).classList.add('hidden');
    document.getElementById('result-card')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function showError(msg: string) {
    const el = document.getElementById('error-msg') as HTMLElement;
    el.textContent = msg; el.classList.remove('hidden');
    (document.getElementById('result-card') as HTMLElement).classList.add('hidden');
  }

  document.getElementById('find-btn')?.addEventListener('click', () => {
    const input = (document.getElementById('name-input') as HTMLInputElement).value;
    if (!input.trim()) { showError(currentLang === 'hi' ? 'कृपया अपना नाम दर्ज करें' : 'Please enter your name'); return; }
    const idx = findRashi(input);
    if (idx === null) { showError(currentLang === 'hi' ? 'इस नाम के लिए राशि निर्धारित नहीं हो सकी। हिंदी में प्रयास करें।' : 'Could not determine Rashi for this name. Try entering it in Hindi.'); return; }
    showResult(idx);
  });

  document.getElementById('name-input')?.addEventListener('keydown', (e) => { if (e.key === 'Enter') document.getElementById('find-btn')?.click(); });

  window.addEventListener('lang-change', ((e: CustomEvent) => {
    currentLang = e.detail.lang;
    const card = document.getElementById('result-card');
    if (card && !card.classList.contains('hidden')) {
      const input = (document.getElementById('name-input') as HTMLInputElement).value;
      const idx = findRashi(input);
      if (idx !== null) showResult(idx);
    }
  }) as EventListener);
</script>
