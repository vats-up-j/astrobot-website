---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
---

<Layout title="Rashi Calculator - Find Your Zodiac Sign | HoroTalk">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-saffron">Home</a> &rsaquo; Rashi Calculator
      </p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight">Find Your Rashi</h1>
      <p class="mt-4 text-text-light text-lg max-w-2xl" id="page-subtitle">
        Enter your name to discover your Vedic moon sign (Rashi) based on the traditional Nakshatra-Pada syllable system.
      </p>
    </div>
  </section>

  <!-- Calculator -->
  <section class="py-12 md:py-16">
    <div class="max-w-xl mx-auto px-4 sm:px-6">

      <!-- Input Card -->
      <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-xl shadow-charcoal/5">
        <label for="name-input" class="block text-sm font-semibold text-charcoal mb-2" id="input-label">Enter your name</label>
        <p class="text-xs text-charcoal/50 mb-4" id="input-hint">Works with Hindi (हिंदी) and English names</p>
        <div class="flex gap-3">
          <input
            type="text"
            id="name-input"
            placeholder="e.g. Arjun or अर्जुन"
            autocomplete="off"
            class="flex-1 px-4 py-3 border border-border rounded-xl focus:ring-2 focus:ring-saffron focus:border-saffron outline-none text-base"
          />
          <button
            id="find-btn"
            class="bg-saffron hover:bg-saffron/90 text-white font-bold px-6 py-3 rounded-xl transition-all active:scale-95"
          >
            <span id="btn-text">Find</span>
          </button>
        </div>
      </div>

      <!-- Result Card (hidden initially) -->
      <div id="result-card" class="mt-6 bg-white rounded-3xl p-6 sm:p-8 shadow-xl shadow-charcoal/5 hidden">
        <!-- Sign header -->
        <div class="flex items-center gap-4 mb-6">
          <div class="w-16 h-16 rounded-full bg-saffron/10 border-2 border-saffron flex items-center justify-center">
            <span id="result-symbol" class="text-3xl text-saffron" style="font-variant-emoji:text"></span>
          </div>
          <div>
            <div id="result-name" class="text-xl font-bold text-charcoal"></div>
            <div id="result-element" class="text-sm text-charcoal/60"></div>
          </div>
        </div>

        <!-- Details grid -->
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="bg-cream rounded-xl p-4">
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40 mb-1" id="label-ruler">Ruling Planet</div>
            <div id="result-ruler" class="text-sm font-semibold text-charcoal"></div>
          </div>
          <div class="bg-cream rounded-xl p-4">
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40 mb-1" id="label-compatible">Compatible With</div>
            <div id="result-compatible" class="text-sm font-semibold text-charcoal"></div>
          </div>
          <div class="bg-cream rounded-xl p-4">
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40 mb-1" id="label-lucky-num">Lucky Number</div>
            <div id="result-lucky-num" class="text-sm font-semibold text-saffron"></div>
          </div>
          <div class="bg-cream rounded-xl p-4">
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40 mb-1" id="label-lucky-color">Lucky Color</div>
            <div id="result-lucky-color" class="text-sm font-semibold text-charcoal"></div>
          </div>
        </div>

        <!-- Traits -->
        <div class="bg-cream rounded-xl p-4 mb-6 border-l-4 border-saffron">
          <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40 mb-1" id="label-traits">Key Traits</div>
          <div id="result-traits" class="text-sm text-charcoal/80 leading-relaxed"></div>
        </div>

        <!-- Disclaimer + CTA -->
        <p class="text-xs text-charcoal/40 mb-4 text-center" id="result-disclaimer">
          This is based on your name's first syllable. For your exact Moon sign from your birth chart, get a personalized reading.
        </p>
        <a
          href={waLink('Hi HoroTalk, I want to know my exact Rashi from my birth chart')}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full bg-[#25D366] text-white py-4 rounded-full font-bold text-center hover:bg-[#25D366]/90 transition-all shadow-lg shadow-[#25D366]/20 active:scale-95 flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span id="cta-text">Get Exact Rashi from Birth Chart</span>
        </a>
      </div>

      <!-- Error message -->
      <div id="error-msg" class="mt-4 text-center text-sm text-red-500 hidden"></div>

    </div>
  </section>

</Layout>

<script>
  // ── Rashi metadata ──────────────────────────────────────────
  const rashiData = [
    { symbol: '\u2648', name: { en: 'Mesha (Aries)', hi: 'मेष' }, element: { en: 'Fire', hi: 'अग्नि' }, ruler: { en: 'Mars (Mangal)', hi: 'मंगल' }, lucky: { num: 9, color: { en: 'Red', hi: 'लाल' } }, compatible: { en: 'Leo, Sagittarius', hi: 'सिंह, धनु' }, traits: { en: 'Bold, ambitious, energetic, pioneering, courageous', hi: 'साहसी, महत्वाकांक्षी, ऊर्जावान, अग्रणी, निडर' } },
    { symbol: '\u2649', name: { en: 'Vrishabha (Taurus)', hi: 'वृषभ' }, element: { en: 'Earth', hi: 'पृथ्वी' }, ruler: { en: 'Venus (Shukra)', hi: 'शुक्र' }, lucky: { num: 6, color: { en: 'Green', hi: 'हरा' } }, compatible: { en: 'Virgo, Capricorn', hi: 'कन्या, मकर' }, traits: { en: 'Stable, loyal, patient, practical, determined', hi: 'स्थिर, वफादार, धैर्यवान, व्यावहारिक, दृढ़' } },
    { symbol: '\u264A', name: { en: 'Mithuna (Gemini)', hi: 'मिथुन' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Mercury (Budh)', hi: 'बुध' }, lucky: { num: 5, color: { en: 'Yellow', hi: 'पीला' } }, compatible: { en: 'Libra, Aquarius', hi: 'तुला, कुंभ' }, traits: { en: 'Curious, adaptable, witty, sociable, expressive', hi: 'जिज्ञासु, अनुकूलनीय, हाजिरजवाब, मिलनसार, अभिव्यक्तिशील' } },
    { symbol: '\u264B', name: { en: 'Karka (Cancer)', hi: 'कर्क' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Moon (Chandra)', hi: 'चंद्रमा' }, lucky: { num: 2, color: { en: 'White', hi: 'सफेद' } }, compatible: { en: 'Scorpio, Pisces', hi: 'वृश्चिक, मीन' }, traits: { en: 'Nurturing, intuitive, protective, emotional, loyal', hi: 'पालनकर्ता, सहज ज्ञानी, सुरक्षात्मक, भावनात्मक, वफादार' } },
    { symbol: '\u264C', name: { en: 'Simha (Leo)', hi: 'सिंह' }, element: { en: 'Fire', hi: 'अग्नि' }, ruler: { en: 'Sun (Surya)', hi: 'सूर्य' }, lucky: { num: 1, color: { en: 'Gold', hi: 'सुनहरा' } }, compatible: { en: 'Aries, Sagittarius', hi: 'मेष, धनु' }, traits: { en: 'Confident, generous, warm-hearted, creative, leader', hi: 'आत्मविश्वासी, उदार, दयालु, रचनात्मक, नेता' } },
    { symbol: '\u264D', name: { en: 'Kanya (Virgo)', hi: 'कन्या' }, element: { en: 'Earth', hi: 'पृथ्वी' }, ruler: { en: 'Mercury (Budh)', hi: 'बुध' }, lucky: { num: 5, color: { en: 'Green', hi: 'हरा' } }, compatible: { en: 'Taurus, Capricorn', hi: 'वृषभ, मकर' }, traits: { en: 'Analytical, meticulous, reliable, modest, practical', hi: 'विश्लेषणात्मक, सावधान, विश्वसनीय, विनम्र, व्यावहारिक' } },
    { symbol: '\u264E', name: { en: 'Tula (Libra)', hi: 'तुला' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Venus (Shukra)', hi: 'शुक्र' }, lucky: { num: 6, color: { en: 'Blue', hi: 'नीला' } }, compatible: { en: 'Gemini, Aquarius', hi: 'मिथुन, कुंभ' }, traits: { en: 'Diplomatic, fair-minded, social, graceful, balanced', hi: 'कूटनीतिक, न्यायप्रिय, सामाजिक, शालीन, संतुलित' } },
    { symbol: '\u264F', name: { en: 'Vrishchika (Scorpio)', hi: 'वृश्चिक' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Mars (Mangal)', hi: 'मंगल' }, lucky: { num: 9, color: { en: 'Maroon', hi: 'गहरा लाल' } }, compatible: { en: 'Cancer, Pisces', hi: 'कर्क, मीन' }, traits: { en: 'Intense, resourceful, brave, passionate, strategic', hi: 'तीव्र, साधनसंपन्न, बहादुर, जुनूनी, रणनीतिक' } },
    { symbol: '\u2650', name: { en: 'Dhanu (Sagittarius)', hi: 'धनु' }, element: { en: 'Fire', hi: 'अग्नि' }, ruler: { en: 'Jupiter (Guru)', hi: 'बृहस्पति' }, lucky: { num: 3, color: { en: 'Purple', hi: 'बैंगनी' } }, compatible: { en: 'Aries, Leo', hi: 'मेष, सिंह' }, traits: { en: 'Optimistic, adventurous, generous, philosophical, honest', hi: 'आशावादी, साहसी, उदार, दार्शनिक, ईमानदार' } },
    { symbol: '\u2651', name: { en: 'Makara (Capricorn)', hi: 'मकर' }, element: { en: 'Earth', hi: 'पृथ्वी' }, ruler: { en: 'Saturn (Shani)', hi: 'शनि' }, lucky: { num: 8, color: { en: 'Brown', hi: 'भूरा' } }, compatible: { en: 'Taurus, Virgo', hi: 'वृषभ, कन्या' }, traits: { en: 'Disciplined, responsible, ambitious, patient, practical', hi: 'अनुशासित, जिम्मेदार, महत्वाकांक्षी, धैर्यवान, व्यावहारिक' } },
    { symbol: '\u2652', name: { en: 'Kumbha (Aquarius)', hi: 'कुंभ' }, element: { en: 'Air', hi: 'वायु' }, ruler: { en: 'Saturn (Shani)', hi: 'शनि' }, lucky: { num: 8, color: { en: 'Sky Blue', hi: 'आसमानी' } }, compatible: { en: 'Gemini, Libra', hi: 'मिथुन, तुला' }, traits: { en: 'Innovative, independent, humanitarian, visionary, original', hi: 'नवप्रवर्तक, स्वतंत्र, मानवतावादी, दूरदर्शी, मौलिक' } },
    { symbol: '\u2653', name: { en: 'Meena (Pisces)', hi: 'मीन' }, element: { en: 'Water', hi: 'जल' }, ruler: { en: 'Jupiter (Guru)', hi: 'बृहस्पति' }, lucky: { num: 3, color: { en: 'Sea Green', hi: 'समुद्री हरा' } }, compatible: { en: 'Cancer, Scorpio', hi: 'कर्क, वृश्चिक' }, traits: { en: 'Compassionate, artistic, intuitive, gentle, wise', hi: 'दयालु, कलात्मक, सहज ज्ञानी, कोमल, बुद्धिमान' } },
  ];

  // ── Syllable → Rashi index mapping (Nakshatra-Pada based) ───
  // Longest match first for romanized input
  const syllableMap: Record<string, number> = {
    // Mesha (0): Ashwini + Bharani + Krittika-1
    'chu': 0, 'che': 0, 'cho': 0,
    'la': 0, 'li': 0, 'lu': 0, 'le': 0, 'lo': 0,
    // Vrishabha (1): Krittika 2-4 + Rohini + Mrigashira 1-2
    'va': 1, 'vi': 1, 'vu': 1, 've': 1, 'vo': 1,
    'ba': 1, 'bi': 1, 'bu': 1, 'be': 1, 'bo': 1,
    'wa': 1, 'wi': 1, 'wu': 1, 'we': 1, 'wo': 1,
    // Mithuna (2): Mrigashira 3-4 + Ardra + Punarvasu 1-3
    'ka': 2, 'ki': 2, 'ku': 2, 'ke': 2, 'ko': 2,
    'gha': 2, 'ha': 2,
    // Karka (3): Punarvasu-4 + Pushya + Ashlesha
    'hi': 3, 'hu': 3, 'he': 3, 'ho': 3,
    'da': 3, 'di': 3, 'du': 3, 'de': 3, 'do': 3,
    // Simha (4): Magha + Purva Phalguni + Uttara Phalguni-1
    'ma': 4, 'mi': 4, 'mu': 4, 'me': 4, 'mo': 4,
    'ta': 4, 'ti': 4, 'tu': 4, 'te': 4,
    // Kanya (5): Uttara Phalguni 2-4 + Hasta + Chitra 1-2
    'to': 5, 'pa': 5, 'pi': 5, 'pu': 5,
    'sha': 5, 'shi': 5, 'shu': 5, 'she': 5, 'sho': 5,
    'tha': 5, 'pe': 5, 'po': 5,
    // Tula (6): Chitra 3-4 + Swati + Vishakha 1-3
    'ra': 6, 'ri': 6, 'ru': 6, 're': 6, 'ro': 6,
    // Vrishchika (7): Vishakha-4 + Anuradha + Jyeshtha
    'na': 7, 'ni': 7, 'nu': 7, 'ne': 7, 'no': 7,
    'ya': 7, 'yi': 7, 'yu': 7,
    // Dhanu (8): Moola + Purva Ashadha + Uttara Ashadha-1
    'ye': 8, 'yo': 8,
    'bha': 8, 'bhi': 8, 'bhu': 8, 'bhe': 8,
    'dha': 8, 'dhi': 8, 'dhu': 8,
    'pha': 8, 'phi': 8, 'phu': 8, 'fa': 8, 'fi': 8, 'fu': 8,
    // Makara (9): Uttara Ashadha 2-4 + Shravana + Dhanishta 1-2
    'bho': 8,
    'ja': 9, 'ji': 9, 'ju': 9, 'je': 9, 'jo': 9,
    'kha': 9, 'khi': 9, 'khu': 9, 'khe': 9, 'kho': 9,
    // Kumbha (10): Dhanishta 3-4 + Shatabhisha + P.Bhadrapada 1-3
    'ga': 10, 'gi': 10, 'gu': 10, 'ge': 10, 'go': 10,
    'sa': 10, 'si': 10, 'su': 10, 'se': 10, 'so': 10,
    // Meena (11): P.Bhadrapada-4 + U.Bhadrapada + Revati
    'cha': 11, 'chi': 11,
    'jha': 11,
  };

  // Devanagari consonant → Rashi index
  const devanagariMap: Record<string, number> = {
    'अ': 0, 'आ': 0, 'ल': 0,
    'इ': 1, 'ई': 1, 'उ': 1, 'ऊ': 1, 'ए': 1, 'ऐ': 1, 'ओ': 1, 'औ': 1,
    'ब': 1, 'व': 1,
    'क': 2, 'छ': 2, 'घ': 2, 'ह': 2,
    'ड': 3, 'ढ': 3,
    'म': 4, 'ट': 4,
    'प': 5, 'ठ': 5, 'ण': 5, 'श': 5, 'ष': 5,
    'र': 6, 'त': 6,
    'न': 7, 'य': 7,
    'भ': 8, 'ध': 8, 'फ': 8,
    'ज': 9, 'ख': 9,
    'ग': 10, 'स': 10,
    'च': 11, 'द': 11, 'थ': 11, 'झ': 11,
  };

  // ── Lookup function ─────────────────────────────────────────
  function findRashi(name: string): number | null {
    const trimmed = name.trim();
    if (!trimmed) return null;

    const firstChar = trimmed.charAt(0);

    // Check if Devanagari
    if (/[\u0900-\u097F]/.test(firstChar)) {
      // Try first character (base consonant)
      const base = firstChar.normalize('NFD').charAt(0);
      if (devanagariMap[base] !== undefined) return devanagariMap[base];
      if (devanagariMap[firstChar] !== undefined) return devanagariMap[firstChar];
      return null;
    }

    // Romanized: try longest match first (3, 2, 1 chars)
    const lower = trimmed.toLowerCase();
    for (const len of [3, 2]) {
      const syllable = lower.substring(0, len);
      if (syllableMap[syllable] !== undefined) return syllableMap[syllable];
    }

    // Single vowel fallback
    const first = lower.charAt(0);
    if (first === 'a') return 0;  // Aries
    if ('ieou'.includes(first)) return 1;  // Taurus (Krittika padas)

    return null;
  }

  // ── UI Logic ────────────────────────────────────────────────
  let currentLang = 'en';

  function showResult(rashiIdx: number) {
    const r = rashiData[rashiIdx];
    const lang = currentLang as 'en' | 'hi';

    (document.getElementById('result-symbol') as HTMLElement).textContent = r.symbol;
    (document.getElementById('result-name') as HTMLElement).textContent = r.name[lang];
    (document.getElementById('result-element') as HTMLElement).textContent = r.element[lang];
    (document.getElementById('result-ruler') as HTMLElement).textContent = r.ruler[lang];
    (document.getElementById('result-compatible') as HTMLElement).textContent = r.compatible[lang];
    (document.getElementById('result-lucky-num') as HTMLElement).textContent = String(r.lucky.num);
    (document.getElementById('result-lucky-color') as HTMLElement).textContent = r.lucky.color[lang];
    (document.getElementById('result-traits') as HTMLElement).textContent = r.traits[lang];

    (document.getElementById('result-card') as HTMLElement).classList.remove('hidden');
    (document.getElementById('error-msg') as HTMLElement).classList.add('hidden');

    // Scroll to result
    document.getElementById('result-card')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function showError(msg: string) {
    const el = document.getElementById('error-msg') as HTMLElement;
    el.textContent = msg;
    el.classList.remove('hidden');
    (document.getElementById('result-card') as HTMLElement).classList.add('hidden');
  }

  // Event listeners
  document.getElementById('find-btn')?.addEventListener('click', () => {
    const input = (document.getElementById('name-input') as HTMLInputElement).value;
    if (!input.trim()) {
      showError(currentLang === 'hi' ? 'कृपया अपना नाम दर्ज करें' : 'Please enter your name');
      return;
    }
    const idx = findRashi(input);
    if (idx === null) {
      showError(currentLang === 'hi' ? 'इस नाम के लिए राशि निर्धारित नहीं की जा सकी। कृपया हिंदी में प्रयास करें।' : 'Could not determine Rashi for this name. Try entering it in Hindi.');
      return;
    }
    showResult(idx);
  });

  document.getElementById('name-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') document.getElementById('find-btn')?.click();
  });

  // Language toggle support
  window.addEventListener('lang-change', ((e: CustomEvent) => {
    currentLang = e.detail.lang;
    // If result is visible, re-render it
    const card = document.getElementById('result-card');
    if (card && !card.classList.contains('hidden')) {
      const input = (document.getElementById('name-input') as HTMLInputElement).value;
      const idx = findRashi(input);
      if (idx !== null) showResult(idx);
    }
  }) as EventListener);
</script>
