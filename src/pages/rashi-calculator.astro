---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
import dailyData from '../data/daily-horoscope.json';

const rashiFaqs = [
  {
    qEn: "What is Rashi in Vedic astrology?",
    qHi: "वैदिक ज्योतिष में राशि क्या है?",
    aEn: "Rashi is your Vedic zodiac sign, determined by the position of the Moon at the time of your birth. Unlike Western astrology which uses the Sun sign, Vedic astrology considers the Moon sign (Rashi) as the primary indicator of personality, emotions, and life path. There are 12 Rashis: Mesha, Vrishabha, Mithuna, Karka, Simha, Kanya, Tula, Vrishchika, Dhanu, Makara, Kumbha, and Meena.",
    aHi: "राशि आपकी वैदिक राशि चिन्ह है, जो जन्म के समय चंद्रमा की स्थिति से निर्धारित होती है। पश्चिमी ज्योतिष सूर्य राशि का उपयोग करता है, लेकिन वैदिक ज्योतिष चंद्र राशि को व्यक्तित्व और जीवन पथ का प्रमुख संकेतक मानता है। 12 राशियां हैं: मेष, वृषभ, मिथुन, कर्क, सिंह, कन्या, तुला, वृश्चिक, धनु, मकर, कुंभ और मीन।"
  },
  {
    qEn: "How accurate is Rashi by name?",
    qHi: "नाम से राशि कितनी सटीक है?",
    aEn: "Finding Rashi by name uses the traditional Nakshatra-Pada syllable system, where each first syllable maps to a specific Nakshatra and Rashi. This method is widely used in Indian families when the birth time is not known. However, for the most accurate Rashi, you need your exact birth time, date, and place to calculate the Moon's precise position. HoroTalk can compute your exact Moon sign on WhatsApp.",
    aHi: "नाम से राशि खोजना पारंपरिक नक्षत्र-पद अक्षर प्रणाली का उपयोग करता है। यह तरीका भारतीय परिवारों में व्यापक रूप से उपयोग होता है जब जन्म समय ज्ञात नहीं होता। सबसे सटीक राशि के लिए, आपको अपना सही जन्म समय, तिथि और स्थान चाहिए। HoroTalk WhatsApp पर आपकी सटीक चंद्र राशि गणना कर सकता है।"
  },
  {
    qEn: "What is the difference between Rashi and Sun sign?",
    qHi: "राशि और सन साइन में क्या अंतर है?",
    aEn: "Your Rashi (Moon sign) is based on the Moon's position in the Vedic sidereal zodiac at birth. Your Sun sign (used in Western astrology) is based on the Sun's position in the tropical zodiac. Most Indians have different Rashi and Sun signs because the two systems differ by about 24 degrees. Vedic astrology considers the Moon sign more important for predictions and compatibility.",
    aHi: "आपकी राशि (चंद्र राशि) जन्म के समय वैदिक साइन राशिचक्र में चंद्रमा की स्थिति पर आधारित है। सन साइन (पश्चिमी ज्योतिष) सूर्य की स्थिति पर। दोनों प्रणालियों में लगभग 24 अंश का अंतर होता है, इसलिए अधिकांश भारतीयों की राशि और सन साइन अलग होती है। वैदिक ज्योतिष भविष्यवाणी के लिए चंद्र राशि को अधिक महत्वपूर्ण मानता है।"
  },
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": rashiFaqs.map(f => ({ "@type": "Question", "name": f.qEn, "acceptedAnswer": { "@type": "Answer", "text": f.aEn } }))
});
---

<Layout title="Rashi Calculator - Find Your Zodiac Sign by Name | HoroTalk">

  <script type="application/ld+json" set:html={faqSchema} />

  <!-- Header -->
  <section class="bg-gradient-to-br from-ivory via-primary-light to-ivory py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <p class="text-sm text-charcoal/40 mb-2">
        <a href="/" class="hover:text-maroon">Home</a> &rsaquo; <span class="i18n" data-en="Rashi Calculator" data-hi="राशि कैलकुलेटर">Rashi Calculator</span>
      </p>
      <h1 class="text-2xl md:text-3xl font-bold text-charcoal i18n" data-en="Find Your Rashi" data-hi="अपनी राशि जानें">Find Your Rashi</h1>
      <p class="mt-2 text-charcoal/50 text-sm i18n" data-en="Enter your name to discover your Vedic moon sign based on the traditional Nakshatra-Pada syllable system." data-hi="पारंपरिक नक्षत्र-पद अक्षर प्रणाली के आधार पर अपनी वैदिक चंद्र राशि जानने के लिए अपना नाम दर्ज करें।">Enter your name to discover your Vedic moon sign based on the traditional Nakshatra-Pada syllable system.</p>
    </div>
  </section>

  <section class="py-6 sm:py-10">
    <div class="max-w-2xl mx-auto px-4 sm:px-8">

      <!-- Input -->
      <div class="bg-white rounded-xl p-5 shadow-md border border-charcoal/5 mb-6">
        <label for="name-input" class="block text-sm font-semibold text-charcoal mb-1 i18n" data-en="Enter your name" data-hi="अपना नाम दर्ज करें">Enter your name</label>
        <p class="text-[11px] text-charcoal/40 mb-3 i18n" data-en="Works with Hindi and English names" data-hi="हिंदी और अंग्रेजी नाम दोनों के साथ काम करता है">Works with Hindi and English names</p>
        <div class="flex gap-2">
          <input type="text" id="name-input" placeholder="e.g. Arjun or अर्जुन" autocomplete="off"
            class="flex-1 px-4 py-3 border border-charcoal/10 rounded-lg focus:ring-2 focus:ring-maroon/30 focus:border-maroon outline-none text-base" />
          <button id="find-btn" class="bg-maroon hover:bg-maroon-dark text-white font-bold px-5 py-3 rounded-lg transition-all active:scale-95 i18n" data-en="Find" data-hi="खोजें">Find</button>
        </div>
      </div>

      <!-- Error -->
      <div id="error-msg" class="mb-4 text-center text-sm text-red-500 hidden"></div>

      <!-- Result (hidden initially) -->
      <div id="result-card" class="bg-white rounded-xl p-5 shadow-md border border-charcoal/5 hidden mb-6">
        <!-- Sign header -->
        <div class="flex items-center gap-3 mb-4">
          <div class="w-14 h-14 rounded-xl bg-maroon/8 border border-maroon/15 flex items-center justify-center">
            <span id="result-symbol" class="text-2xl" style="font-variant-emoji:text"></span>
          </div>
          <div>
            <div id="result-name" class="text-lg font-bold text-charcoal"></div>
            <div id="result-element" class="text-xs text-charcoal/50"></div>
          </div>
        </div>

        <!-- Details -->
        <div class="grid grid-cols-2 gap-2.5 mb-4">
          <div class="bg-ivory rounded-lg p-3">
            <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-0.5 i18n" data-en="Ruling Planet" data-hi="स्वामी ग्रह">Ruling Planet</div>
            <div id="result-ruler" class="text-sm font-semibold text-charcoal"></div>
          </div>
          <div class="bg-ivory rounded-lg p-3">
            <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-0.5 i18n" data-en="Compatible With" data-hi="अनुकूल राशि">Compatible With</div>
            <div id="result-compatible" class="text-sm font-semibold text-charcoal"></div>
          </div>
          <div class="bg-ivory rounded-lg p-3">
            <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-0.5 i18n" data-en="Lucky Number" data-hi="शुभ अंक">Lucky Number</div>
            <div id="result-lucky-num" class="text-sm font-semibold text-maroon"></div>
          </div>
          <div class="bg-ivory rounded-lg p-3">
            <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-0.5 i18n" data-en="Lucky Color" data-hi="शुभ रंग">Lucky Color</div>
            <div id="result-lucky-color" class="text-sm font-semibold text-charcoal"></div>
          </div>
        </div>

        <!-- Traits -->
        <div class="bg-ivory rounded-lg p-3 mb-4 border-l-3 border-maroon">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-0.5 i18n" data-en="Key Traits" data-hi="मुख्य गुण">Key Traits</div>
          <div id="result-traits" class="text-sm text-charcoal/70 leading-relaxed"></div>
        </div>

        <!-- Today's horoscope snippet for this sign -->
        <div id="result-horoscope" class="bg-maroon/5 rounded-lg p-3 mb-4 border border-maroon/10">
          <div class="text-[8px] uppercase tracking-widest font-bold text-maroon/40 mb-0.5 i18n" data-en="Today's Reading for Your Rashi" data-hi="आपकी राशि के लिए आज का राशिफल">Today's Reading for Your Rashi</div>
          <p id="result-horoscope-text" class="text-xs text-charcoal/60 leading-relaxed"></p>
        </div>

        <!-- CTA -->
        <p class="text-[11px] text-charcoal/40 mb-3 text-center i18n" data-en="This is based on your name's first syllable. For your exact Moon sign from your birth chart, get a personalized reading." data-hi="यह आपके नाम के पहले अक्षर पर आधारित है। अपनी कुंडली से सटीक चंद्र राशि जानने के लिए, व्यक्तिगत रीडिंग प्राप्त करें।">This is based on your name's first syllable. For your exact Moon sign from your birth chart, get a personalized reading.</p>
        <a href={waLink('Hi HoroTalk, I want to know my exact Rashi from my birth chart')} target="_blank" rel="noopener noreferrer"
          class="block w-full bg-[#25D366] text-white py-3 rounded-lg font-bold text-center text-sm hover:bg-[#25D366]/90 transition-all shadow-lg shadow-[#25D366]/20 active:scale-95 flex items-center justify-center gap-2">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="i18n" data-en="Get Exact Rashi from Birth Chart" data-hi="कुंडली से सटीक राशि जानें">Get Exact Rashi from Birth Chart</span>
        </a>
      </div>

      <!-- Internal links -->
      <div class="flex flex-wrap gap-2 mb-8">
        <a href="/" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">&larr; Daily Horoscope</a>
        <a href="/panchang" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">Today's Panchang &rarr;</a>
      </div>

      <!-- SEO content -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="How Does Rashi by Name Work?" data-hi="नाम से राशि कैसे काम करती है?">How Does Rashi by Name Work?</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="text-sm text-charcoal/55 leading-relaxed space-y-2">
          <p class="i18n" data-en="In Vedic astrology, every name is connected to a Nakshatra (birth star) through its first syllable. There are 27 Nakshatras, each divided into 4 Padas (quarters). Each Pada has a specific starting syllable assigned to it. Since every Nakshatra maps to one of the 12 Rashis, your name's first syllable can indicate your Rashi." data-hi="वैदिक ज्योतिष में, हर नाम अपने पहले अक्षर के माध्यम से एक नक्षत्र से जुड़ा होता है। 27 नक्षत्र हैं, प्रत्येक 4 पदों में विभाजित। प्रत्येक पद का एक विशिष्ट प्रारंभिक अक्षर होता है। चूंकि हर नक्षत्र 12 राशियों में से एक से जुड़ता है, आपके नाम का पहला अक्षर आपकी राशि बता सकता है।">In Vedic astrology, every name is connected to a Nakshatra (birth star) through its first syllable. There are 27 Nakshatras, each divided into 4 Padas (quarters). Each Pada has a specific starting syllable assigned to it. Since every Nakshatra maps to one of the 12 Rashis, your name's first syllable can indicate your Rashi.</p>
          <p class="i18n" data-en="This is why many Indian families choose baby names based on the child's birth Nakshatra, ensuring the name aligns with their Rashi. The name-based method is a quick approximation. For the most accurate result, HoroTalk can calculate your exact Moon sign using your precise birth time, date, and location." data-hi="इसीलिए कई भारतीय परिवार बच्चे के जन्म नक्षत्र के आधार पर नाम चुनते हैं। नाम-आधारित विधि एक त्वरित अनुमान है। सबसे सटीक परिणाम के लिए, HoroTalk आपके सही जन्म समय, तिथि और स्थान से आपकी सटीक चंद्र राशि गणना कर सकता है।">This is why many Indian families choose baby names based on the child's birth Nakshatra, ensuring the name aligns with their Rashi. The name-based method is a quick approximation. For the most accurate result, HoroTalk can calculate your exact Moon sign using your precise birth time, date, and location.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="Common Questions" data-hi="आम प्रश्न">Common Questions</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="space-y-2">
          {rashiFaqs.map(faq => (
            <details class="group bg-white rounded-xl border border-charcoal/5 shadow-sm">
              <summary class="px-4 py-3 cursor-pointer flex justify-between items-center text-sm font-semibold text-charcoal list-none">
                <span class="i18n" data-en={faq.qEn} data-hi={faq.qHi}>{faq.qEn}</span>
                <svg class="w-4 h-4 text-charcoal/30 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-3 text-xs text-charcoal/55 leading-relaxed">
                <span class="i18n" data-en={faq.aEn} data-hi={faq.aHi}>{faq.aEn}</span>
              </div>
            </details>
          ))}
        </div>
      </div>

    </div>
  </section>

  <style>
    details summary::-webkit-details-marker { display: none; }
  </style>

</Layout>

<script is:inline define:vars={{ dailySignsJson: JSON.stringify(dailyData.signs) }}>
  window.__dailySigns = JSON.parse(dailySignsJson);
</script>

<script>
  const rashiData = [
    { symbol: '\u2648', id: 'aries', name: { en: 'Mesha (Aries)', hi: 'मेष' }, element: { en: 'Fire', hi: 'अग्नि' }, ruler: { en: 'Mars (Mangal)', hi: 'मंगल' }, lucky: { num: 9, color: { en: 'Red', hi: 'लाल' } }, compatible: { en: 'Leo, Sagittarius', hi: 'सिंह, धनु' }, traits: { en: 'Bold, ambitious, energetic, pioneering, courageous', hi: 'साहसी, महत्वाकांक्षी, ऊर्जावान, अग्रणी, निडर' } },
