---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
import festivalData from '../data/festivals-2026.json';

const { festivals } = festivalData;

// Group by month
const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const monthsHi = ['जनवरी','फरवरी','मार्च','अप्रैल','मई','जून','जुलाई','अगस्त','सितंबर','अक्टूबर','नवंबर','दिसंबर'];
const byMonth: Record<number, typeof festivals> = {};
festivals.forEach(f => {
  const m = new Date(f.date + 'T00:00:00Z').getUTCMonth();
  if (!byMonth[m]) byMonth[m] = [];
  byMonth[m].push(f);
});

// Upcoming (next 5 from today)
const today = new Date().toISOString().split('T')[0];
const upcoming = festivals.filter(f => f.date >= today).slice(0, 5);

// Type badge classes
const typeBadge: Record<string, { label: string, labelHi: string, cls: string }> = {
  festival: { label: 'Festival', labelHi: 'त्योहार', cls: 'bg-maroon/10 text-maroon' },
  vrat: { label: 'Vrat', labelHi: 'व्रत', cls: 'bg-gold/20 text-gold' },
  ekadashi: { label: 'Ekadashi', labelHi: 'एकादशी', cls: 'bg-blue-50 text-blue-600' },
  purnima: { label: 'Purnima', labelHi: 'पूर्णिमा', cls: 'bg-purple-50 text-purple-600' },
  amavasya: { label: 'Amavasya', labelHi: 'अमावस्या', cls: 'bg-charcoal/5 text-charcoal/60' },
  transit: { label: 'Transit', labelHi: 'संक्रांति', cls: 'bg-green-50 text-green-600' },
};

const calFaqs = [
  { qEn: "How many Hindu festivals are there in 2026?", qHi: "2026 में कितने हिंदू त्योहार हैं?", aEn: "The Hindu calendar for 2026 includes approximately 30 major festivals, 24 Ekadashi fasting days, 12 Purnima dates, and numerous regional observances. Key festivals include Holi, Ram Navami, Janmashtami, Navratri, Dussehra, Diwali, and Chhath Puja.", aHi: "2026 के हिंदू कैलेंडर में लगभग 30 प्रमुख त्योहार, 24 एकादशी व्रत, 12 पूर्णिमा तिथियां शामिल हैं। प्रमुख त्योहारों में होली, राम नवमी, जन्माष्टमी, नवरात्रि, दशहरा, दिवाली और छठ पूजा शामिल हैं।" },
  { qEn: "When is Diwali in 2026?", qHi: "2026 में दिवाली कब है?", aEn: "Diwali 2026 falls on Sunday, November 8. Dhanteras is on November 6, and Bhai Dooj is on November 11.", aHi: "दिवाली 2026 रविवार, 8 नवंबर को है। धनतेरस 6 नवंबर को और भाई दूज 11 नवंबर को है।" },
  { qEn: "When is Navratri in 2026?", qHi: "2026 में नवरात्रि कब है?", aEn: "Chaitra Navratri 2026 begins on March 19 (Gudi Padwa). Sharad Navratri 2026 begins on October 11 and ends with Dussehra on October 20.", aHi: "चैत्र नवरात्रि 2026 19 मार्च (गुड़ी पड़वा) से शुरू होती है। शरद नवरात्रि 2026 11 अक्टूबर से शुरू होकर 20 अक्टूबर दशहरा पर समाप्त होती है।" },
  { qEn: "What is Ekadashi and how often does it occur?", qHi: "एकादशी क्या है और कितनी बार आती है?", aEn: "Ekadashi is the 11th day of each lunar fortnight, occurring twice a month (once in Shukla Paksha and once in Krishna Paksha). There are 24 Ekadashis in a regular year. Fasting on Ekadashi is considered highly meritorious in Hindu tradition, especially Nirjala Ekadashi (waterless fast) which falls on June 25 in 2026.", aHi: "एकादशी हर चंद्र पक्ष का 11वां दिन है, महीने में दो बार आती है। साल में 24 एकादशी होती हैं। एकादशी व्रत हिंदू परंपरा में अत्यंत पुण्यकारी माना जाता है, विशेषकर निर्जला एकादशी जो 2026 में 25 जून को है।" },
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": calFaqs.map(f => ({ "@type": "Question", "name": f.qEn, "acceptedAnswer": { "@type": "Answer", "text": f.aEn } }))
});
---

<Layout title="Hindu Calendar 2026 - Festivals, Vrats, Ekadashi Dates | HoroTalk">

  <script type="application/ld+json" set:html={faqSchema} />

  <!-- Header -->
  <section class="bg-gradient-to-br from-ivory via-primary-light to-ivory py-8 md:py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-8">
      <p class="text-sm text-charcoal/40 mb-2">
        <a href="/" class="hover:text-maroon">Home</a> &rsaquo; <span class="i18n" data-en="Calendar" data-hi="कैलेंडर">Calendar</span>
      </p>
      <h1 class="text-2xl md:text-3xl font-bold text-charcoal i18n" data-en="Hindu Calendar 2026" data-hi="हिंदू कैलेंडर 2026">Hindu Calendar 2026</h1>
      <p class="mt-2 text-charcoal/50 text-sm i18n" data-en="Complete list of Hindu festivals, Ekadashi dates, Purnima, Amavasya, and vrat days for 2026. Vikram Samvat 2082-2083." data-hi="2026 के सभी हिंदू त्योहार, एकादशी, पूर्णिमा, अमावस्या और व्रत की पूरी सूची। विक्रम संवत 2082-2083।">Complete list of Hindu festivals, Ekadashi dates, Purnima, Amavasya, and vrat days for 2026. Vikram Samvat 2082-2083.</p>
    </div>
  </section>

  <section class="py-6 sm:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-8">

      <!-- Upcoming -->
      {upcoming.length > 0 && (
        <div class="mb-8">
          <h2 class="text-base font-bold text-charcoal mb-3 i18n" data-en="Coming Up Next" data-hi="आगामी">Coming Up Next</h2>
          <div class="flex gap-2 overflow-x-auto pb-2 scrollbar-hide">
            {upcoming.map(f => {
              const d = new Date(f.date + 'T00:00:00Z');
              const badge = typeBadge[f.type] || typeBadge.festival;
              return (
                <div class="flex-shrink-0 bg-white rounded-xl p-3 shadow-sm border border-charcoal/5 min-w-[160px]">
                  <div class="text-[9px] uppercase tracking-wider font-bold text-charcoal/30 mb-1">{d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', weekday: 'short', timeZone: 'UTC' })}</div>
                  <div class="text-sm font-semibold text-charcoal mb-1">
                    <span class="panchang-en">{f.nameEn}</span>
                    <span class="panchang-hi hidden">{f.nameHi}</span>
                  </div>
                  <span class={`text-[8px] font-bold px-1.5 py-0.5 rounded-full ${badge.cls}`}>
                    <span class="panchang-en">{badge.label}</span>
                    <span class="panchang-hi hidden">{badge.labelHi}</span>
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <!-- Filter tabs -->
      <div class="flex gap-1.5 mb-6 overflow-x-auto pb-1 scrollbar-hide" id="filter-tabs">
        <button data-filter="all" class="filter-tab active text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">All</button>
        <button data-filter="festival" class="filter-tab text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">Festivals</button>
        <button data-filter="ekadashi" class="filter-tab text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">Ekadashi</button>
        <button data-filter="purnima" class="filter-tab text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">Purnima</button>
        <button data-filter="vrat" class="filter-tab text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">Vrat</button>
        <button data-filter="amavasya" class="filter-tab text-xs font-semibold px-3 py-1.5 rounded-full transition-colors">Amavasya</button>
      </div>

      <!-- Month-wise calendar -->
      <div id="calendar-grid" class="space-y-6 mb-10">
        {Object.entries(byMonth).sort(([a],[b]) => Number(a)-Number(b)).map(([monthIdx, items]) => (
          <div class="cal-month">
            <h3 class="text-base font-bold text-charcoal mb-2 sticky top-16 bg-ivory py-1 z-10">
              <span class="panchang-en">{months[Number(monthIdx)]}</span>
              <span class="panchang-hi hidden">{monthsHi[Number(monthIdx)]}</span>
              <span class="text-charcoal/30 text-sm font-normal ml-1">2026</span>
            </h3>
            <div class="space-y-1">
              {items.map(f => {
                const d = new Date(f.date + 'T00:00:00Z');
                const badge = typeBadge[f.type] || typeBadge.festival;
                const dayStr = d.toLocaleDateString('en-US', { day: 'numeric', weekday: 'short', timeZone: 'UTC' });
                return (
                  <div class={`cal-item flex items-center gap-3 py-2 px-3 rounded-lg hover:bg-white hover:shadow-sm transition-all`} data-type={f.type}>
                    <div class="text-xs text-charcoal/40 font-medium w-16 flex-shrink-0">{dayStr}</div>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-semibold text-charcoal">
                        <span class="panchang-en">{f.nameEn}</span>
                        <span class="panchang-hi hidden">{f.nameHi}</span>
                      </span>
                      {f.descEn && <span class="text-xs text-charcoal/40 ml-1.5 hidden sm:inline">
                        <span class="panchang-en">{f.descEn}</span>
                        <span class="panchang-hi hidden">{f.descHi}</span>
                      </span>}
                    </div>
                    <span class={`text-[8px] font-bold px-1.5 py-0.5 rounded-full flex-shrink-0 ${badge.cls}`}>
                      <span class="panchang-en">{badge.label}</span>
                      <span class="panchang-hi hidden">{badge.labelHi}</span>
                    </span>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>

      <!-- Internal links -->
      <div class="flex flex-wrap gap-2 mb-8">
        <a href="/" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">&larr; Daily Horoscope</a>
        <a href="/panchang" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">Today's Panchang &rarr;</a>
        <a href="/rashi-calculator" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">Find Your Rashi &rarr;</a>
      </div>

      <!-- SEO content -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="About the Hindu Calendar" data-hi="हिंदू कैलेंडर के बारे में">About the Hindu Calendar</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="text-sm text-charcoal/55 leading-relaxed space-y-2">
          <p class="i18n" data-en="The Hindu calendar is a lunisolar system used to determine the dates of festivals, vrats (fasting days), and religious ceremonies. The year 2026 corresponds to Vikram Samvat 2082-2083 and includes all major festivals from Makar Sankranti in January to Margashirsha Purnima in December." data-hi="हिंदू कैलेंडर एक चंद्र-सौर प्रणाली है जो त्योहारों, व्रतों और धार्मिक अनुष्ठानों की तिथियां निर्धारित करती है। वर्ष 2026 विक्रम संवत 2082-2083 के अनुरूप है।">The Hindu calendar is a lunisolar system used to determine the dates of festivals, vrats (fasting days), and religious ceremonies. The year 2026 corresponds to Vikram Samvat 2082-2083 and includes all major festivals from Makar Sankranti in January to Margashirsha Purnima in December.</p>
          <p class="i18n" data-en="Festival dates are determined by the positions of the Sun and Moon. HoroTalk computes these from astronomical data to ensure accuracy. Ekadashi (11th lunar day) occurs twice monthly and is widely observed as a fasting day. Purnima (full moon) and Amavasya (new moon) days have special significance for rituals and charity." data-hi="त्योहारों की तिथियां सूर्य और चंद्रमा की स्थिति से निर्धारित होती हैं। एकादशी (11वां चंद्र दिवस) महीने में दो बार आती है और व्यापक रूप से व्रत का दिन है। पूर्णिमा और अमावस्या के दिन अनुष्ठान और दान के लिए विशेष महत्व रखते हैं।">Festival dates are determined by the positions of the Sun and Moon. HoroTalk computes these from astronomical data to ensure accuracy. Ekadashi (11th lunar day) occurs twice monthly and is widely observed as a fasting day. Purnima (full moon) and Amavasya (new moon) days have special significance for rituals and charity.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="Common Questions" data-hi="आम प्रश्न">Common Questions</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="space-y-2">
          {calFaqs.map(faq => (
            <details class="group bg-white rounded-xl border border-charcoal/5 shadow-sm">
              <summary class="px-4 py-3 cursor-pointer flex justify-between items-center text-sm font-semibold text-charcoal list-none">
                <span class="i18n" data-en={faq.qEn} data-hi={faq.qHi}>{faq.qEn}</span>
                <svg class="w-4 h-4 text-charcoal/30 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-3 text-xs text-charcoal/55 leading-relaxed">
                <span class="i18n" data-en={faq.aEn} data-hi={faq.aHi}>{faq.aEn}</span>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-maroon rounded-2xl p-5 sm:p-7 text-center shadow-xl shadow-maroon/20">
        <h3 class="text-base font-bold text-white mb-1 i18n" data-en="Need Muhurta for a Special Occasion?" data-hi="विशेष अवसर के लिए मुहूर्त चाहिए?">Need Muhurta for a Special Occasion?</h3>
        <p class="text-[11px] text-white/55 mb-4 i18n" data-en="Get personalized auspicious timings based on your birth chart for weddings, business, travel, and more." data-hi="विवाह, व्यापार, यात्रा के लिए अपनी कुंडली के आधार पर शुभ मुहूर्त प्राप्त करें।">Get personalized auspicious timings based on your birth chart for weddings, business, travel, and more.</p>
        <a href={waLink('Hi HoroTalk, I need a muhurta for an important event')} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold px-6 py-3 rounded-lg text-sm transition-all active:scale-[0.97] shadow-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="i18n" data-en="Ask HoroTalk on WhatsApp" data-hi="WhatsApp पर HoroTalk से पूछें">Ask HoroTalk on WhatsApp</span>
        </a>
      </div>

    </div>
  </section>

  <style>
    details summary::-webkit-details-marker { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .filter-tab { background: rgba(45,24,16,0.04); color: rgba(45,24,16,0.5); }
    .filter-tab:hover { background: rgba(45,24,16,0.08); }
    .filter-tab.active { background: #7B2D26; color: white; }
    .cal-item.hidden-by-filter { display: none; }
  </style>

</Layout>

<script>
  // Filter functionality
  document.querySelectorAll('.filter-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const filter = (tab as HTMLElement).dataset.filter;
      document.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      document.querySelectorAll('.cal-item').forEach(item => {
        const type = (item as HTMLElement).dataset.type;
        if (filter === 'all' || type === filter) {
          item.classList.remove('hidden-by-filter');
        } else {
          item.classList.add('hidden-by-filter');
        }
      });

      // Hide empty months
      document.querySelectorAll('.cal-month').forEach(month => {
        const visible = month.querySelectorAll('.cal-item:not(.hidden-by-filter)').length;
        (month as HTMLElement).style.display = visible > 0 ? '' : 'none';
      });
    });
  });

  // Language toggle
  window.addEventListener('lang-change', ((e: CustomEvent) => {
    const lang = e.detail.lang as 'en' | 'hi';
    document.querySelectorAll('.panchang-en').forEach(el => el.classList.toggle('hidden', lang === 'hi'));
    document.querySelectorAll('.panchang-hi').forEach(el => el.classList.toggle('hidden', lang === 'en'));
  }) as EventListener);
</script>
