---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
import dailyData from '../data/daily-horoscope.json';

const { panchang, date } = dailyData;

// Format display date
const displayDate = new Date(date + 'T00:00:00Z');
const dateEn = displayDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const dateHi = displayDate.toLocaleDateString('hi-IN', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<Layout title="Today's Panchang - Tithi, Nakshatra, Yoga | HoroTalk">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-saffron">Home</a> &rsaquo; Panchang
      </p>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight" id="page-title">Today's Panchang</h1>
      <p class="mt-3 text-charcoal/60 text-base md:text-lg">
        <span id="date-en">{dateEn}</span>
        <span id="date-hi" class="hidden">{dateHi}</span>
      </p>
    </div>
  </section>

  <!-- Panchang Cards -->
  <section class="py-12 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">

      <!-- Main Panchang Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">

        <!-- Tithi -->
        <div class="bg-white rounded-2xl p-6 shadow-lg shadow-charcoal/5 border border-charcoal/5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-saffron/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
            </div>
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40" data-label-en="Tithi" data-label-hi="तिथि">Tithi</div>
          </div>
          <div class="text-lg font-bold text-charcoal">
            <span class="panchang-en">{panchang.tithi.en}</span>
            <span class="panchang-hi hidden">{panchang.tithi.hi}</span>
          </div>
        </div>

        <!-- Nakshatra -->
        <div class="bg-white rounded-2xl p-6 shadow-lg shadow-charcoal/5 border border-charcoal/5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-saffron/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40" data-label-en="Nakshatra" data-label-hi="नक्षत्र">Nakshatra</div>
          </div>
          <div class="text-lg font-bold text-charcoal">
            <span class="panchang-en">{panchang.nakshatra.en}</span>
            <span class="panchang-hi hidden">{panchang.nakshatra.hi}</span>
          </div>
        </div>

        <!-- Yoga -->
        <div class="bg-white rounded-2xl p-6 shadow-lg shadow-charcoal/5 border border-charcoal/5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-saffron/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40" data-label-en="Yoga" data-label-hi="योग">Yoga</div>
          </div>
          <div class="text-lg font-bold text-charcoal">
            <span class="panchang-en">{panchang.yoga.en}</span>
            <span class="panchang-hi hidden">{panchang.yoga.hi}</span>
          </div>
        </div>

        <!-- Karana -->
        <div class="bg-white rounded-2xl p-6 shadow-lg shadow-charcoal/5 border border-charcoal/5">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-saffron/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </div>
            <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40" data-label-en="Karana" data-label-hi="करण">Karana</div>
          </div>
          <div class="text-lg font-bold text-charcoal">
            <span class="panchang-en">{panchang.karana.en}</span>
            <span class="panchang-hi hidden">{panchang.karana.hi}</span>
          </div>
        </div>
      </div>

      <!-- Var (Day) -->
      <div class="bg-white rounded-2xl p-6 shadow-lg shadow-charcoal/5 border border-charcoal/5 mb-8">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-saffron/10 rounded-full flex items-center justify-center">
            <svg class="w-5 h-5 text-saffron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div class="text-[10px] uppercase tracking-widest font-bold text-charcoal/40" data-label-en="Day (Var)" data-label-hi="वार">Day (Var)</div>
        </div>
        <div class="text-lg font-bold text-charcoal">
          <span class="panchang-en">{panchang.var.en}</span>
          <span class="panchang-hi hidden">{panchang.var.hi}</span>
        </div>
      </div>

      <!-- Info note -->
      <div class="bg-cream rounded-2xl p-5 border-l-4 border-saffron mb-8">
        <p class="text-sm text-charcoal/70 leading-relaxed" id="info-text">
          Panchang data is computed daily using real planetary positions via Swiss Ephemeris-grade astronomical algorithms with Lahiri ayanamsa. Updated automatically every morning.
        </p>
      </div>

      <!-- WhatsApp CTA -->
      <div class="bg-white rounded-3xl p-6 sm:p-8 shadow-xl shadow-charcoal/5 text-center">
        <h3 class="text-lg sm:text-xl font-bold text-charcoal mb-2" id="cta-title">Need Personalized Muhurta?</h3>
        <p class="text-sm text-charcoal/60 mb-5" id="cta-sub">
          Get auspicious timings based on your birth chart for important events — marriage, business, travel, and more.
        </p>
        <a
          href={waLink('Hi HoroTalk, I need a personalized muhurta')}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white px-8 py-4 rounded-full font-bold hover:bg-[#25D366]/90 transition-all shadow-lg shadow-[#25D366]/20 active:scale-95"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span id="cta-btn-text">Ask HoroTalk for Muhurta</span>
        </a>
      </div>

    </div>
  </section>

</Layout>

<script>
  // Language toggle support
  window.addEventListener('lang-change', ((e: CustomEvent) => {
    const lang = e.detail.lang as 'en' | 'hi';

    // Toggle panchang values
    document.querySelectorAll('.panchang-en').forEach(el => el.classList.toggle('hidden', lang === 'hi'));
    document.querySelectorAll('.panchang-hi').forEach(el => el.classList.toggle('hidden', lang === 'en'));

    // Toggle date
    document.getElementById('date-en')?.classList.toggle('hidden', lang === 'hi');
    document.getElementById('date-hi')?.classList.toggle('hidden', lang === 'en');

    // Toggle labels
    document.querySelectorAll('[data-label-en]').forEach(el => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = lang === 'hi' ? (htmlEl.dataset.labelHi || '') : (htmlEl.dataset.labelEn || '');
    });
  }) as EventListener);
</script>
