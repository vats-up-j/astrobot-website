<script>
  window.addEventListener('lang-change', ((e: CustomEvent) => {
    const lang = e.detail.lang as 'en' | 'hi';
    document.querySelectorAll('.panchang-en').forEach(el => el.classList.toggle('hidden', lang === 'hi'));
    document.querySelectorAll('.panchang-hi').forEach(el => el.classList.toggle('hidden', lang === 'en'));
    document.getElementById('date-en')?.classList.toggle('hidden', lang === 'hi');
    document.getElementById('date-hi')?.classList.toggle('hidden', lang === 'en');
    document.querySelectorAll('[data-label-en]').forEach(el => {
      const h = el as HTMLElement;
      h.textContent = lang === 'hi' ? (h.dataset.labelHi || '') : (h.dataset.labelEn || '');
    });
  }) as EventListener);
</script>
