---
import Layout from '../layouts/Layout.astro';
import { waLink } from '../config';
import dailyData from '../data/daily-horoscope.json';

const { panchang, date } = dailyData;

const displayDate = new Date(date + 'T00:00:00Z');
const dateEn = displayDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const dateHi = displayDate.toLocaleDateString('hi-IN', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

// Verdict color
const verdictColors: Record<string, string> = {
  'Highly Auspicious': 'text-green-700 bg-green-50 border-green-200',
  'Auspicious': 'text-green-600 bg-green-50/50 border-green-100',
  'Moderate': 'text-gold bg-gold-light border-gold/20',
  'Exercise Caution': 'text-maroon bg-maroon-light border-maroon/20',
};
const verdictClass = verdictColors[panchang.verdict?.en || 'Moderate'] || verdictColors['Moderate'];

const panchangFaqs = [
  {
    qEn: "What is Panchang?",
    qHi: "पंचांग क्या है?",
    aEn: "Panchang is the traditional Vedic Hindu calendar that tracks five key elements: Tithi (lunar day), Nakshatra (birth star), Yoga (planetary combination), Karana (half-tithi), and Var (day of the week). These five elements determine the auspiciousness of any given day for important activities like marriage, travel, business, and rituals.",
    aHi: "पंचांग पारंपरिक वैदिक हिंदू कैलेंडर है जो पांच मुख्य तत्वों को ट्रैक करता है: तिथि, नक्षत्र, योग, करण और वार। ये पांच तत्व किसी भी दिन की शुभता निर्धारित करते हैं।"
  },
  {
    qEn: "What is Tithi?",
    qHi: "तिथि क्या है?",
    aEn: "Tithi is the lunar day based on the angular distance between the Sun and Moon. There are 30 tithis in a lunar month, divided into Shukla Paksha (waxing moon) and Krishna Paksha (waning moon). Each tithi has specific qualities that make it suitable or unsuitable for different activities.",
    aHi: "तिथि सूर्य और चंद्रमा के बीच कोणीय दूरी पर आधारित चंद्र दिवस है। एक चंद्र मास में 30 तिथियां होती हैं, शुक्ल पक्ष और कृष्ण पक्ष में।"
  },
  {
    qEn: "What is Rahu Kaal and why should I avoid it?",
    qHi: "राहु काल क्या है और इससे क्यों बचना चाहिए?",
    aEn: "Rahu Kaal is a daily period of approximately 1.5 hours ruled by the shadow planet Rahu. It is considered inauspicious for starting new work, signing contracts, or beginning journeys. The timing changes each day of the week. Routine activities are fine during Rahu Kaal, but important new beginnings should be avoided.",
    aHi: "राहु काल लगभग 1.5 घंटे की दैनिक अवधि है जो छाया ग्रह राहु द्वारा शासित होती है। नए कार्य शुरू करने, अनुबंध पर हस्ताक्षर करने या यात्रा शुरू करने के लिए इसे अशुभ माना जाता है। सामान्य कार्य राहु काल में ठीक हैं।"
  },
  {
    qEn: "How is this Panchang calculated?",
    qHi: "यह पंचांग कैसे गणना किया जाता है?",
    aEn: "HoroTalk computes Panchang using Swiss Ephemeris-grade astronomical algorithms. Tithi is derived from the Moon-Sun angular distance. Nakshatra from the Moon's sidereal longitude using Lahiri ayanamsa. Yoga from the sum of Sun and Moon sidereal longitudes. All data refreshes automatically every morning based on real planetary positions.",
    aHi: "HoroTalk Swiss Ephemeris स्तर के खगोलीय एल्गोरिदम से पंचांग की गणना करता है। तिथि चंद्र-सूर्य कोणीय दूरी से, नक्षत्र चंद्रमा की साइन रेखांश से, और योग सूर्य-चंद्र रेखांश के योग से। सभी डेटा हर सुबह स्वतः अपडेट होता है।"
  },
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org", "@type": "FAQPage",
  "mainEntity": panchangFaqs.map(f => ({ "@type": "Question", "name": f.qEn, "acceptedAnswer": { "@type": "Answer", "text": f.aEn } }))
});
---

<Layout title="Today's Panchang - Tithi, Nakshatra, Rahu Kaal | HoroTalk">

  <script type="application/ld+json" set:html={faqSchema} />

  <!-- Header -->
  <section class="bg-gradient-to-br from-ivory via-primary-light to-ivory py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">
      <p class="text-sm text-charcoal/40 mb-2">
        <a href="/" class="hover:text-maroon">Home</a> &rsaquo; Panchang
      </p>
      <h1 class="text-2xl md:text-3xl font-bold text-charcoal">
        <span class="i18n" data-en="Today's Panchang" data-hi="आज का पंचांग">Today's Panchang</span>
      </h1>
      <p class="mt-1 text-charcoal/50 text-sm">
        <span id="date-en">{dateEn}</span><span id="date-hi" class="hidden">{dateHi}</span>
      </p>
    </div>
  </section>

  <section class="py-6 sm:py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-8">

      <!-- Today's verdict (the #1 thing people want) -->
      {panchang.verdict && (
        <div class={`rounded-xl p-4 sm:p-5 mb-6 border ${verdictClass} flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3`}>
          <div>
            <div class="text-[9px] uppercase tracking-widest font-bold opacity-60 mb-1">
              <span class="i18n" data-en="Today's Verdict" data-hi="आज का निर्णय">Today's Verdict</span>
            </div>
            <div class="text-xl font-bold font-heading">
              <span class="panchang-en">{panchang.verdict.en}</span>
              <span class="panchang-hi hidden">{panchang.verdict.hi}</span>
            </div>
          </div>
          {panchang.specialDay && (
            <div class="bg-white/80 rounded-lg px-3 py-1.5 text-xs font-semibold border border-charcoal/5">
              <span class="panchang-en">{panchang.specialDay.en}</span>
              <span class="panchang-hi hidden">{panchang.specialDay.hi}</span>
            </div>
          )}
        </div>
      )}

      <!-- 5 Panchang elements + Rahu Kaal -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-2.5 mb-6">
        <div class="bg-white rounded-xl p-3.5 shadow-sm border border-charcoal/5">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-1" data-label-en="Tithi" data-label-hi="तिथि">Tithi</div>
          <div class="text-sm font-bold text-charcoal"><span class="panchang-en">{panchang.tithi.en}</span><span class="panchang-hi hidden">{panchang.tithi.hi}</span></div>
        </div>
        <div class="bg-white rounded-xl p-3.5 shadow-sm border border-charcoal/5">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-1" data-label-en="Nakshatra" data-label-hi="नक्षत्र">Nakshatra</div>
          <div class="text-sm font-bold text-charcoal"><span class="panchang-en">{panchang.nakshatra.en}</span><span class="panchang-hi hidden">{panchang.nakshatra.hi}</span></div>
        </div>
        <div class="bg-white rounded-xl p-3.5 shadow-sm border border-charcoal/5">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-1" data-label-en="Yoga" data-label-hi="योग">Yoga</div>
          <div class="text-sm font-bold text-charcoal"><span class="panchang-en">{panchang.yoga.en}</span><span class="panchang-hi hidden">{panchang.yoga.hi}</span></div>
        </div>
        <div class="bg-white rounded-xl p-3.5 shadow-sm border border-charcoal/5">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-1" data-label-en="Karana" data-label-hi="करण">Karana</div>
          <div class="text-sm font-bold text-charcoal"><span class="panchang-en">{panchang.karana.en}</span><span class="panchang-hi hidden">{panchang.karana.hi}</span></div>
        </div>
        <div class="bg-white rounded-xl p-3.5 shadow-sm border border-charcoal/5">
          <div class="text-[8px] uppercase tracking-widest font-bold text-charcoal/30 mb-1" data-label-en="Day" data-label-hi="वार">Day</div>
          <div class="text-sm font-bold text-charcoal"><span class="panchang-en">{panchang.var.en}</span><span class="panchang-hi hidden">{panchang.var.hi}</span></div>
        </div>
        {panchang.rahuKaal && (
          <div class="bg-maroon-light rounded-xl p-3.5 shadow-sm border border-maroon/10">
            <div class="text-[8px] uppercase tracking-widest font-bold text-maroon/50 mb-1" data-label-en="Rahu Kaal" data-label-hi="राहु काल">Rahu Kaal</div>
            <div class="text-sm font-bold text-maroon">{panchang.rahuKaal.start} - {panchang.rahuKaal.end}</div>
          </div>
        )}
      </div>

      <!-- Good for / Avoid today -->
      <div class="grid sm:grid-cols-2 gap-3 mb-8">
        <div class="bg-green-50/50 rounded-xl p-4 border border-green-100">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-green-600 text-sm">&#x2714;</span>
            <span class="text-[9px] uppercase tracking-widest font-bold text-green-700/60 i18n" data-en="Good for today" data-hi="आज के लिए शुभ">Good for today</span>
          </div>
          <p class="text-sm text-green-800/70 leading-relaxed">
            <span class="panchang-en">{panchang.goodFor?.en}</span>
            <span class="panchang-hi hidden">{panchang.goodFor?.hi}</span>
          </p>
        </div>
        <div class="bg-maroon-light rounded-xl p-4 border border-maroon/10">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-maroon text-sm">&#x26A0;</span>
            <span class="text-[9px] uppercase tracking-widest font-bold text-maroon/50 i18n" data-en="Be mindful" data-hi="ध्यान रखें">Be mindful</span>
          </div>
          <p class="text-sm text-maroon/60 leading-relaxed">
            <span class="panchang-en">{panchang.avoidToday?.en}</span>
            <span class="panchang-hi hidden">{panchang.avoidToday?.hi}</span>
          </p>
        </div>
      </div>

      <!-- Internal links -->
      <div class="flex flex-wrap gap-2 mb-8">
        <a href="/" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">&larr; Daily Horoscope</a>
        <a href="/rashi-calculator" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">Find Your Rashi &rarr;</a>
        <a href="/pricing" class="text-xs bg-maroon/5 text-maroon px-3 py-1.5 rounded-full font-medium hover:bg-maroon/10 transition-colors">View Reports &rarr;</a>
      </div>

      <!-- What is Panchang (SEO content) -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="What is Panchang?" data-hi="पंचांग क्या है?">What is Panchang?</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="text-sm text-charcoal/55 leading-relaxed space-y-2">
          <p class="i18n" data-en="Panchang (also spelled Panchangam) is the Vedic Hindu calendar that guides daily life decisions. The word comes from Sanskrit: 'Pancha' meaning five and 'Anga' meaning limb. These five limbs are Tithi (lunar day), Nakshatra (star constellation), Yoga (Sun-Moon combination), Karana (half-tithi), and Var (weekday)." data-hi="पंचांग (पंचांगम) वैदिक हिंदू कैलेंडर है जो दैनिक जीवन के निर्णयों का मार्गदर्शन करता है। यह शब्द संस्कृत से आता है: 'पंच' यानी पांच और 'अंग' यानी अंग। ये पांच अंग हैं: तिथि, नक्षत्र, योग, करण और वार।">Panchang (also spelled Panchangam) is the Vedic Hindu calendar that guides daily life decisions. The word comes from Sanskrit: 'Pancha' meaning five and 'Anga' meaning limb. These five limbs are Tithi (lunar day), Nakshatra (star constellation), Yoga (Sun-Moon combination), Karana (half-tithi), and Var (weekday).</p>
          <p class="i18n" data-en="Millions of people check the Panchang daily before starting important work, planning travel, scheduling ceremonies, or choosing auspicious timings (muhurta). HoroTalk computes these values from actual planetary positions every morning, ensuring accuracy." data-hi="करोड़ों लोग महत्वपूर्ण कार्य शुरू करने, यात्रा की योजना बनाने या शुभ मुहूर्त चुनने से पहले प्रतिदिन पंचांग देखते हैं। HoroTalk हर सुबह वास्तविक ग्रह स्थिति से गणना करता है।">Millions of people check the Panchang daily before starting important work, planning travel, scheduling ceremonies, or choosing auspicious timings (muhurta). HoroTalk computes these values from actual planetary positions every morning, ensuring accuracy.</p>
        </div>
      </div>

      <!-- FAQ -->
      <div class="mb-8">
        <h2 class="text-lg font-bold text-charcoal mb-1 i18n" data-en="Common Questions" data-hi="आम प्रश्न">Common Questions</h2>
        <div class="w-8 h-0.5 bg-gold rounded-full mb-3"></div>
        <div class="space-y-2">
          {panchangFaqs.map(faq => (
            <details class="group bg-white rounded-xl border border-charcoal/5 shadow-sm">
              <summary class="px-4 py-3 cursor-pointer flex justify-between items-center text-sm font-semibold text-charcoal list-none">
                <span class="i18n" data-en={faq.qEn} data-hi={faq.qHi}>{faq.qEn}</span>
                <svg class="w-4 h-4 text-charcoal/30 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-4 pb-3 text-xs text-charcoal/55 leading-relaxed">
                <span class="i18n" data-en={faq.aEn} data-hi={faq.aHi}>{faq.aEn}</span>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-maroon rounded-2xl p-5 sm:p-7 text-center shadow-xl shadow-maroon/20">
        <h3 class="text-base font-bold text-white mb-1 i18n" data-en="Need Personalized Muhurta?" data-hi="व्यक्तिगत मुहूर्त चाहिए?">Need Personalized Muhurta?</h3>
        <p class="text-[11px] text-white/55 mb-4 i18n" data-en="Get auspicious timings based on your birth chart for marriage, business, travel, and more." data-hi="विवाह, व्यापार, यात्रा के लिए अपनी कुंडली के आधार पर शुभ समय प्राप्त करें।">Get auspicious timings based on your birth chart for marriage, business, travel, and more.</p>
        <a href={waLink('Hi HoroTalk, I need a personalized muhurta')} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold/90 text-navy font-bold px-6 py-3 rounded-lg text-sm transition-all active:scale-[0.97] shadow-lg">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="i18n" data-en="Ask HoroTalk on WhatsApp" data-hi="WhatsApp पर HoroTalk से पूछें">Ask HoroTalk on WhatsApp</span>
        </a>
      </div>

      <!-- Source note -->
      <p class="mt-6 text-[10px] text-charcoal/30 text-center i18n" data-en="Data computed from real planetary positions using Lahiri ayanamsa. Auto-updated daily." data-hi="लाहिरी अयनांश से वास्तविक ग्रह स्थिति से गणना। प्रतिदिन स्वतः अपडेट।">Data computed from real planetary positions using Lahiri ayanamsa. Auto-updated daily.</p>

    </div>
  </section>

  <style>
    details summary::-webkit-details-marker { display: none; }
  </style>

</Layout>

<script>
  window.addEventListener('lang-change', ((e: CustomEvent) => {
    const lang = e.detail.lang as 'en' | 'hi';
    document.querySelectorAll('.panchang-en').forEach(el => el.classList.toggle('hidden', lang === 'hi'));
    document.querySelectorAll('.panchang-hi').forEach(el => el.classList.toggle('hidden', lang === 'en'));
    document.getElementById('date-en')?.classList.toggle('hidden', lang === 'hi');
    document.getElementById('date-hi')?.classList.toggle('hidden', lang === 'en');
    document.querySelectorAll('[data-label-en]').forEach(el => {
      const h = el as HTMLElement;
      h.textContent = lang === 'hi' ? (h.dataset.labelHi || '') : (h.dataset.labelEn || '');
    });
  }) as EventListener);
</script>
