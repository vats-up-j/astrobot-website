---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - AstroBot">

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-white via-primary-light to-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-sm text-text-light mb-2">
        <a href="/" class="hover:text-primary">Home</a> &rsaquo; Contact
      </p>
      <h1 class="text-3xl md:text-5xl font-bold">Get in Touch</h1>
      <p class="mt-4 text-text-light text-lg max-w-2xl">
        Have a question, feedback, or partnership inquiry? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">

        <!-- WhatsApp -->
        <div class="text-center border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-green-600" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">WhatsApp</h3>
          <p class="text-text-light text-sm mb-4">The fastest way to reach us. Chat directly with our team.</p>
          <a
            href="https://wa.me/919999999999?text=Hi%2C%20I%20have%20a%20question%20about%20AstroBot"
            target="_blank"
            rel="noopener noreferrer"
            class="text-green-600 font-medium text-sm hover:underline"
          >
            Message us on WhatsApp &rarr;
          </a>
        </div>

        <!-- Email -->
        <div class="text-center border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-primary-light rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Email</h3>
          <p class="text-text-light text-sm mb-4">For detailed queries, partnerships, or business inquiries.</p>
          <a
            href="mailto:hello@astrobot.in"
            class="text-primary font-medium text-sm hover:underline"
          >
            hello@astrobot.in &rarr;
          </a>
        </div>

        <!-- Social -->
        <div class="text-center border border-border rounded-xl p-8 hover:shadow-lg transition-shadow">
          <div class="w-14 h-14 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Social Media</h3>
          <p class="text-text-light text-sm mb-4">Follow us for daily astrology tips and updates.</p>
          <p class="text-blue-500 font-medium text-sm">Coming soon</p>
        </div>

      </div>

      <!-- Simple Contact Form -->
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-center mb-8">Send Us a Message</h2>
        <form action="#" method="POST" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium mb-1">Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium mb-1">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm" placeholder="you@example.com" />
            </div>
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium mb-1">Subject</label>
            <select id="subject" name="subject" class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm text-text-light">
              <option>General Question</option>
              <option>Technical Issue</option>
              <option>Billing & Subscription</option>
              <option>Partnership</option>
              <option>Feedback</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium mb-1">Message</label>
            <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none text-sm" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="w-full bg-primary hover:bg-primary-dark text-white font-semibold py-3 rounded-lg transition-colors">
            Send Message
          </button>
          <p class="text-xs text-text-light text-center">For a faster response, message us directly on WhatsApp.</p>
        </form>
      </div>

    </div>
  </section>

</Layout>
