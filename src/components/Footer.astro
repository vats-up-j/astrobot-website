---
const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-light border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z" />
            </svg>
          </div>
          <span class="text-lg font-bold text-text">AstroBot</span>
        </a>
        <p class="text-sm text-text-light leading-relaxed">
          Your personal AI astrologer on WhatsApp. Get instant Vedic astrology readings anytime, anywhere.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-text mb-3">Product</h3>
        <ul class="space-y-2">
          <li><a href="/features" class="text-sm text-text-light hover:text-primary transition-colors">Features</a></li>
          <li><a href="/pricing" class="text-sm text-text-light hover:text-primary transition-colors">Pricing</a></li>
          <li><a href="/about" class="text-sm text-text-light hover:text-primary transition-colors">About</a></li>
        </ul>
      </div>

      <!-- Support -->
      <div>
        <h3 class="text-sm font-semibold text-text mb-3">Support</h3>
        <ul class="space-y-2">
          <li><a href="/contact" class="text-sm text-text-light hover:text-primary transition-colors">Contact Us</a></li>
          <li><a href="/privacy" class="text-sm text-text-light hover:text-primary transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-text-light hover:text-primary transition-colors">Terms of Service</a></li>
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h3 class="text-sm font-semibold text-text mb-3">Chat with Us</h3>
        <a
          href="https://wa.me/919999999999?text=Hi%20AstroBot"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium px-4 py-2.5 rounded-lg transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
        <p class="text-xs text-text-light mt-3">Available 24/7 in Hindi & English</p>
      </div>
    </div>

    <div class="border-t border-border mt-8 pt-8 text-center">
      <p class="text-sm text-text-light">&copy; {currentYear} AstroBot. All rights reserved.</p>
    </div>
  </div>
</footer>
