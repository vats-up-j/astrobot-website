---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-charcoal/10 py-6 px-4 sm:px-12">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-[10px] sm:text-[12px] font-medium text-charcoal/60 text-center sm:text-left">
    <div>Astro<span class="text-saffron">Bot</span> ({currentYear}). All rights reserved.</div>
    <div class="flex items-center gap-6 sm:gap-8">
      <a href="/privacy" class="hover:text-charcoal transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-charcoal transition-colors">Terms of Service</a>
      <a href="/contact" class="hover:text-charcoal transition-colors">Contact</a>
    </div>
  </div>
</footer>
