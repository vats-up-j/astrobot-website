---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-charcoal/10 py-6 px-4 sm:px-8">
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-[10px] sm:text-[12px] font-medium text-charcoal/50 text-center sm:text-left">
    <div class="font-heading"><span class="text-maroon">Horo</span><span class="text-gold">Talk</span> <span class="font-sans">({currentYear}). All rights reserved.</span></div>
    <div class="flex items-center gap-5 sm:gap-8">
      <a href="/privacy" class="hover:text-maroon transition-colors">Privacy Policy</a>
      <a href="/terms" class="hover:text-maroon transition-colors">Terms of Service</a>
      <a href="/contact" class="hover:text-maroon transition-colors">Contact</a>
    </div>
  </div>
</footer>
