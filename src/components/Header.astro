---
const navLinks = [
  { name: "Panchang", href: "/panchang" },
  { name: "Rashi", href: "/rashi-calculator" },
  { name: "Features", href: "/features" },
  { name: "Pricing", href: "/pricing" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 left-0 right-0 z-50 bg-cream/80 backdrop-blur-md border-b border-charcoal/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-12 h-20 flex items-center justify-between">
    <!-- Logo + Language Toggle -->
    <div class="flex flex-col gap-1">
      <a href="/" class="flex items-center gap-2 no-underline">
        <img src="/logo.png" alt="HoroTalk" class="w-9 h-9 rounded-lg" />
        <span class="text-xl sm:text-2xl font-bold tracking-tight text-charcoal">Horo<span class="text-saffron">Talk</span></span>
      </a>
      <div class="flex items-center gap-2 bg-charcoal/5 p-1 rounded-lg w-fit">
        <button data-lang="en" class="lang-btn text-[10px] font-bold px-2 py-0.5 rounded transition-all bg-white text-saffron shadow-sm">EN</button>
        <button data-lang="hi" class="lang-btn text-[10px] font-bold px-2 py-0.5 rounded transition-all text-charcoal/40 hover:text-charcoal">HI</button>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="flex items-center gap-4 sm:gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium transition-colors hidden md:block",
            currentPath === link.href ? "text-saffron" : "text-charcoal/60 hover:text-charcoal"
          ]}
        >
          {link.name}
        </a>
      ))}

      <a
        href="https://wa.me/919999999999?text=Hi%20HoroTalk"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-[#25D366] text-white px-3 sm:px-6 py-2 sm:py-2.5 rounded-full text-[9px] sm:text-sm font-bold hover:bg-[#25D366]/90 transition-all shadow-md shadow-[#25D366]/20 active:scale-95 flex items-center gap-1.5 sm:gap-2"
      >
        <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        <span id="header-chat-text">Chat Now</span>
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-charcoal/60 hover:text-charcoal rounded-lg"
        aria-label="Open menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden pb-4 px-4 sm:px-12">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[
          "block py-2 text-sm font-medium",
          currentPath === link.href ? "text-saffron" : "text-charcoal/60"
        ]}
      >
        {link.name}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  document.querySelectorAll('.lang-btn').forEach(langBtn => {
    langBtn.addEventListener('click', () => {
      const lang = (langBtn as HTMLElement).dataset.lang;
      document.querySelectorAll('.lang-btn').forEach(b => {
        if ((b as HTMLElement).dataset.lang === lang) {
          b.className = 'lang-btn text-[10px] font-bold px-2 py-0.5 rounded transition-all bg-white text-saffron shadow-sm';
        } else {
          b.className = 'lang-btn text-[10px] font-bold px-2 py-0.5 rounded transition-all text-charcoal/40 hover:text-charcoal';
        }
      });
      window.dispatchEvent(new CustomEvent('lang-change', { detail: { lang } }));
    });
  });
</script>
